{% extends 'teacher/base.html.twig' %}

{% block title %}My Payslips{% endblock %}

{% block body %}
<div class="container py-4" style="max-width: 1000px;">
    <h2 class="fw-bold text-dark mb-4">My Payslips</h2>

    <div class="card border-0 shadow-sm rounded-4">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light text-muted small fw-bold">
                    <tr>
                        <th class="ps-4 py-3">MONTH</th>
                        <th>PAYMENT DATE</th>
                        <th>NET PAY</th>
                        <th>STATUS</th>
                        <th class="text-end pe-4">ACTION</th>
                    </tr>
                </thead>
                <tbody>
                    {% for slip in payslips %}
                        <tr>
                            <td class="ps-4 fw-bold text-dark">{{ slip.month }}</td>
                            <td>{{ slip.paymentDate|date('M d, Y') }}</td>
                            <td class="fw-bold text-success">${{ slip.netPay|number_format(2) }}</td>
                            <td>
                                <span class="badge bg-success bg-opacity-10 text-success px-3 rounded-pill">
                                    <i class="fas fa-check-circle me-1"></i> {{ slip.status }}
                                </span>
                            </td>
                            <td class="text-end pe-4">
                                <a href="{{ path('teacher_payslip_show', {'id': slip.id}) }}" class="btn btn-primary btn-sm rounded-3 px-3 shadow-sm">
                                    <i class="fas fa-eye me-1"></i> View Slip
                                </a>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="5" class="text-center py-5 text-muted">
                                <i class="fas fa-folder-open fs-2 mb-3 d-block opacity-50"></i>
                                No payslips have been generated for you yet.
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% endblock %}