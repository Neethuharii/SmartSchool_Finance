<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">

    <title>Payslip</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>

        body{
            background:#f4f6f9;
            padding:40px;
            font-family:Arial, sans-serif;
        }

        .slip-container{
            max-width:850px;
            margin:auto;
            background:#fff;
            border-radius:14px;
            padding:40px;
            box-shadow:0 10px 25px rgba(0,0,0,0.05);
        }

        .school-title{
            font-size:28px;
            font-weight:700;
            color:#111827;
        }

        .sub{
            color:#6b7280;
            font-size:14px;
        }

        .section-title{
            font-weight:700;
            color:#111827;
            margin-bottom:18px;
        }

        .table td{
            padding:14px;
        }

        .table thead{
            background:#f3f4f6;
        }

        .amount{
            font-size:32px;
            font-weight:800;
            color:#2563eb;
        }

        .badge-paid{
            background:#dcfce7;
            color:#166534;
            padding:8px 14px;
            border-radius:30px;
            font-size:13px;
            font-weight:700;
        }

        .footer-note{
            margin-top:50px;
            text-align:center;
            color:#6b7280;
            font-size:13px;
        }

        @media print {

            body{
                background:#fff;
                padding:0;
            }

            .print-btn{
                display:none;
            }

            .slip-container{
                box-shadow:none;
                border:none;
            }

        }

    </style>
</head>

<body>

<div class="slip-container">

    <div class="d-flex justify-content-between align-items-start mb-5">

        <div>

            <div class="school-title">
                Arbor Education
            </div>

            <div class="sub">
                Teacher Salary Payslip
            </div>

        </div>

        <button onclick="window.print()" class="btn btn-primary print-btn">
            Print / Save PDF
        </button>

    </div>

    <div class="row mb-4">

        <div class="col-md-6">

            <h6 class="section-title">Teacher Information</h6>

            <table class="table table-bordered">

                <tr>
                    <td><strong>Name</strong></td>
                    <td>{{ teacher.firstName }} {{ teacher.lastName }}</td>
                </tr>

                <tr>
                    <td><strong>Staff ID</strong></td>
                    <td>{{ teacher.staffId }}</td>
                </tr>

                <tr>
                    <td><strong>Month</strong></td>
                    <td>{{ slip.month }}</td>
                </tr>

            </table>

        </div>

        <div class="col-md-6">

            <h6 class="section-title">Payment Details</h6>

            <table class="table table-bordered">

                <tr>
                    <td><strong>Payment Date</strong></td>
                    <td>{{ slip.paymentDate|date('d M Y') }}</td>
                </tr>

                <tr>
                    <td><strong>Status</strong></td>
                    <td>
                        <span class="badge-paid">
                            {{ slip.status }}
                        </span>
                    </td>
                </tr>

                <tr>
                    <td><strong>Net Pay</strong></td>
                    <td class="fw-bold text-primary">
                        ${{ slip.netPay|number_format(2) }}
                    </td>
                </tr>

            </table>

        </div>

    </div>

    <h6 class="section-title">Salary Breakdown</h6>

    <table class="table table-bordered">

        <thead>
        <tr>
            <th>Description</th>
            <th class="text-end">Amount</th>
        </tr>
        </thead>

        <tbody>

        <tr>
            <td>Basic Salary</td>
            <td class="text-end">
                ${{ slip.basicPay|number_format(2) }}
            </td>
        </tr>

        <tr>
            <td>Allowances</td>
            <td class="text-end">
                $0.00
            </td>
        </tr>

        <tr>
            <td>Deductions</td>
            <td class="text-end text-danger">
                - $0.00
            </td>
        </tr>

        <tr>
            <td class="fw-bold">Final Net Salary</td>
            <td class="text-end amount">
                ${{ slip.netPay|number_format(2) }}
            </td>
        </tr>

        </tbody>

    </table>

    <div class="footer-note">

        This is a system generated digital payslip.<br>
        No physical signature required.

    </div>

</div>

</body>
</html>