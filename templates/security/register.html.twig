<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>Register - Arbor ERP</title>

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

  <style>

:root{
    --green:#77b82a;
    --light-green:#c7d92f;
    --orange:#f39a22;
    --dark:#171717;
    --bg:#f7f5f0;
    --card:#ffffff;
    --border:#ebe7dc;
}

/* BASE */
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
}

body{
    font-family:'Inter',sans-serif;
    background:var(--bg);
    height:100vh;
    overflow:hidden;
    color:var(--dark);
}

/* WRAPPER */
.auth-wrapper{
    height:100vh;
    display:flex;
    align-items:center;
    justify-content:center;
    padding:18px;
}
.brand-logo-img{
    width: 70px;
    height: 70px;

}
/* MAIN CARD (MORE DEPTH) */
.auth-container{
    width:100%;
    max-width:1080px;
    height:92vh;
    background:var(--card);
    border-radius:26px;
    overflow:hidden;
    display:grid;
    grid-template-columns:1fr 1fr;

    /* STRONGER BUT SOFT SHADOW */
    box-shadow:
        0 25px 60px rgba(0,0,0,0.08),
        0 8px 20px rgba(0,0,0,0.05);

    border:1px solid var(--border);
}

/* LEFT SIDE (FIXED CONGESTION) */
.left-side{
    background:linear-gradient(180deg,#fbfaf7,#f6f4ee);
    padding:45px 50px;
    position:relative;
    overflow:hidden;

    /* IMPORTANT: better spacing feel */
    display:flex;
    flex-direction:column;
    justify-content:center;
}

/* SOFT BACKGROUND SHAPES */
.circle{
    position:absolute;
    border-radius:50%;
    opacity:0.06;
}

.circle-1{
    width:220px;
    height:220px;
    background:var(--green);
    top:-70px;
    left:-70px;
}

.circle-2{
    width:180px;
    height:180px;
    background:var(--orange);
    bottom:-60px;
    right:-60px;
}

/* BRAND */
.brand-badge{
    display:inline-flex;
    align-items:center;
    padding:8px 14px;
  
    margin-bottom:72px;
    font-size:13px;
    font-weight:600;
    margin-left: 60px;

    
}

/* TEXT */
.left-side h1{
    font-size:2.2rem;
    font-weight:700;
    line-height:1.2;
    margin-bottom:14px;
}

.left-side p{
    font-size:0.92rem;
    color:#666;
    line-height:1.7;
    max-width:420px;
}

/* FEATURES (LESS CRAMPED) */
.feature-list{
    margin-top:26px;
    display:flex;
    flex-direction:column;
    gap:14px;
}

.feature-item{
    display:flex;
    align-items:flex-start;
    gap:12px;
}

/* ICONS */
.feature-icon{
    width:40px;
    height:40px;
    border-radius:12px;
    display:flex;
    align-items:center;
    justify-content:center;
    font-weight:700;
    color:white;
    font-size:13px;

    /* subtle depth */
    box-shadow:0 6px 12px rgba(0,0,0,0.08);
}

.feature-icon.green{ background:var(--green); }
.feature-icon.orange{ background:var(--orange); }
.feature-icon.yellow{
    background:var(--light-green);
    color:#222;
}

/* FEATURE TEXT */
.feature-item h6{
    font-size:14px;
    margin-bottom:2px;
    font-weight:700;
}

.feature-item p{
    font-size:12.5px;
    margin:0;
    color:#777;
}

/* RIGHT SIDE */
.right-side{
    padding:45px 55px;
    display:flex;
    align-items:center;
    background:white;
}

/* FORM */
.form-title{
    font-size:1.8rem;
    font-weight:700;
    margin-bottom:6px;
}

.form-subtitle{
    color:#777;
    margin-bottom:22px;
    font-size:13px;
}

/* INPUTS */
.form-control,
.form-select{
    height:46px;
    border-radius:12px;
    border:1px solid #e8e5dc;
    background:#faf9f6;
    padding:0 12px;
    font-size:14px;
    transition:0.2s ease;
}

.form-control:focus,
.form-select:focus{
    border-color:var(--green);
    box-shadow:0 0 0 3px rgba(119,184,42,0.12);
    background:white;
}

/* BUTTON */
.register-btn{
    height:48px;
    border:none;
    border-radius:14px;
    background:linear-gradient(135deg,var(--green),var(--light-green));
    color:#1f1f1f;
    font-weight:700;
    font-size:14px;

    box-shadow:0 10px 18px rgba(119,184,42,0.18);
}

.register-btn:hover{
    transform:translateY(-1px);
    box-shadow:0 14px 26px rgba(119,184,42,0.25);
}

/* LINKS */
.signin-link{
    color:var(--green);
    font-weight:700;
    text-decoration:none;
    font-size:13px;
}

/* SPACING */
.mb-3{
    margin-bottom:0.75rem !important;
}

.mb-4{
    margin-bottom:1rem !important;
}

/* MOBILE */
@media(max-width:992px){

    body{
        overflow:auto;
    }

    .auth-container{
        grid-template-columns:1fr;
        height:auto;
    }

    .left-side{
        display:none;
    }

    .right-side{
        padding:25px;
    }
}

</style>
</head>

<body>

<div class="auth-wrapper">

    <div class="auth-container">

        <!-- LEFT SIDE -->
        <div class="left-side">

            <div class="circle circle-1"></div>
            <div class="circle circle-2"></div>

           <div class="brand-badge">
    <img src="{{ asset('images/arborlogo-removebg-preview.png') }}" alt="Arbor Logo" class="brand-logo-img">
    <span style="font-size: large; " >&nbsp;&nbsp;&nbsp;Arbor Finance </span>
</div>

         <h3>
    Manage smarter <br>
    school finances & payroll <br>
    with <span class="highlight">Arbor Finance</span>
</h3>
<p>
    Simple and secure school finance management in one place.
</p>

            <div class="feature-list">

                <div class="feature-item">

                    <div class="feature-icon green">
                        ✓
                    </div>

                    <div>
                        <h6>Teacher Management</h6>
                        <p>Manage academic and payroll activities easily.</p>
                    </div>

                </div>

                <div class="feature-item">

                    <div class="feature-icon orange">
                        ✓
                    </div>

                    <div>
                        <h6>Finance & Payroll</h6>
                        <p>Track salary slips and financial records securely.</p>
                    </div>

                </div>

                <div class="feature-item">

                    <div class="feature-icon yellow">
                        ✓
                    </div>

                    <div>
                        <h6>Parent Connectivity</h6>
                        <p>Improve communication between schools and families.</p>
                    </div>

                </div>

            </div>

        </div>

        <!-- RIGHT SIDE -->
        <div class="right-side">

            <div class="form-wrapper">

                <h2 class="form-title">
                    Create Account
                </h2>

                <p class="form-subtitle">
                    Register your Arbor ERP profile
                </p>

                <form method="post">

                    <div class="row">

                        <div class="col-md-6 mb-3">

                            <label class="form-label">
                                First Name
                            </label>

                            <input type="text"
                                   name="first_name"
                                   class="form-control"
                                   placeholder="John"
                                   required>

                        </div>

                        <div class="col-md-6 mb-3">

                            <label class="form-label">
                                Last Name
                            </label>

                            <input type="text"
                                   name="last_name"
                                   class="form-control"
                                   placeholder="Doe"
                                   required>

                        </div>

                    </div>

                    <div class="mb-3">

                        <label class="form-label">
                            Email Address
                        </label>

                        <input type="email"
                               name="email"
                               class="form-control"
                               placeholder="name@domain.com"
                               required>

                    </div>

                    <div class="mb-3">

                        <label class="form-label">
                            Phone Number
                        </label>

                        <input type="tel"
                               name="phone"
                               class="form-control"
                               placeholder="+1 555 000 0000"
                               required>

                    </div>

                    <div class="mb-3">

                        <label class="form-label">
                            Account Type
                        </label>

                        <select name="role"
                                class="form-select"
                                required>

                            <option value="" disabled selected>
                                Select account type
                            </option>

                            <option value="ROLE_TEACHER">
                                Teacher / Faculty
                            </option>

                            <option value="ROLE_PARENT">
                                Parent / Guardian
                            </option>

                            <option value="ROLE_FINANCE">
                                Finance Administrator
                            </option>

                            <option value="ROLE_ADMIN">
                                System Admin
                            </option>

                        </select>

                    </div>

                    <div class="mb-4">

                        <label class="form-label">
                            Password
                        </label>

                        <input type="password"
                               name="password"
                               class="form-control"
                               placeholder="Create a secure password"
                               minlength="6"
                               required>

                    </div>

                    <button type="submit"
                            class="btn register-btn w-100 mb-4">

                        Create Account

                    </button>

                    <div class="text-center">

                        <span class="text-muted">
                            Already have an account?
                        </span>

                        <a href="{{ path('app_login') }}"
                           class="signin-link">

                            Sign In

                        </a>

                    </div>

                </form>

            </div>

        </div>

    </div>

</div>

</body>
</html>