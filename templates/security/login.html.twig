<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>Login - Arbor ERP</title>

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>

        :root{
            --green:#77b82a;
            --light-green:#c7d92f;
            --orange:#f39a22;
            --bg:#f7f5f0;
            --card:#ffffff;
            --border:#ebe7dc;
            --dark:#1a1a1a;
        }

        *{
            margin:0;
            padding:0;
            box-sizing:border-box;
        }

        body{
            font-family:'Inter',sans-serif;
            background:var(--bg);
            height:100vh;
            display:flex;
            align-items:center;
            justify-content:center;
        }

        .login-card{
            width:100%;
            max-width:420px;
            background:var(--card);
            border:1px solid var(--border);
            border-radius:26px;
            padding:38px;
            box-shadow:0 20px 50px rgba(0,0,0,0.06);
        }

        .logo-box{
            width:62px;
            height:62px;
            border-radius:18px;
            background:#faf8f3;
            border:1px solid var(--border);
            display:flex;
            align-items:center;
            justify-content:center;
            margin:0 auto 18px;
        }

        .logo-box img{
            width:38px;
        }

        h3{
            font-weight:700;
            text-align:center;
            margin-bottom:6px;
        }

        p{
            text-align:center;
            color:#777;
            font-size:13px;
            margin-bottom:22px;
        }

        .form-label{
            font-size:13px;
            font-weight:600;
            margin-bottom:6px;
        }

        .form-control{
            height:46px;
            border-radius:14px;
            border:1px solid #e8e5dc;
            background:#faf9f6;
            font-size:14px;
        }

        .form-control:focus{
            border-color:var(--green);
            box-shadow:0 0 0 3px rgba(119,184,42,0.12);
            background:white;
        }

        .login-btn{
            height:48px;
            border:none;
            border-radius:14px;
            background:linear-gradient(135deg,var(--green),var(--light-green));
            font-weight:700;
            color:#1a1a1a;
            transition:0.3s;
        }

        .login-btn:hover{
            transform:translateY(-1px);
            box-shadow:0 10px 18px rgba(119,184,42,0.2);
        }

        .small-link{
            color:var(--green);
            font-weight:600;
            text-decoration:none;
            font-size:13px;
        }

        .small-link:hover{
            color:#5e9420;
        }

        .alert{
            border-radius:12px;
            font-size:13px;
        }

    </style>
</head>

<body>

<div class="login-card">

    <!-- LOGO -->
    <div class="logo-box">
        <img src="{{ asset('images/arborlogo-removebg-preview.png') }}" alt="Logo">
    </div>

    <h3>Welcome Back</h3>

    <p>Sign in to your Arbor ERP account</p>

    {% if error %}
        <div class="alert alert-danger">
            {{ error.messageKey|trans(error.messageData, 'security') }}
        </div>
    {% endif %}

    <form method="post">

        <div class="mb-3">

            <label class="form-label">Email Address</label>

            <input type="email"
                   name="_username"
                   value="{{ last_username }}"
                   class="form-control"
                   placeholder="name@school.edu"
                   required>

        </div>

        <div class="mb-2">

            <div class="d-flex justify-content-between">

                <label class="form-label">Password</label>

                <a href="#" class="small-link">Forgot?</a>

            </div>

            <input type="password"
                   name="_password"
                   class="form-control"
                   placeholder="••••••••"
                   required>

        </div>

        <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

        <button type="submit"
                class="btn login-btn w-100 mt-3 mb-3">

            Secure Login

        </button>

     {#   <div class="text-center">

            <span class="text-muted" style="font-size:13px;">
                Don't have an account?
            </span>

            <a href="{{ path('app_register') }}"
               class="small-link">

                Register here

            </a>

        </div>#}

    </form>

</div>

</body>
</html>