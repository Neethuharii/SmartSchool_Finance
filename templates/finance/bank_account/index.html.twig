{% extends 'finance/base.html.twig' %}

{% block title %}Bank Accounts | Finance Portal{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .bank-card {
            border-radius: 20px;
            padding: 25px;
            color: white;
            min-height: 200px;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            position: relative;
            overflow: hidden;
            transition: 0.3s;
            border: none;
        }
        .bank-card:hover { transform: translateY(-5px); box-shadow: 0 10px 20px rgba(0,0,0,0.15); }
        .bank-card .chip { width: 40px; height: 30px; background: rgba(255,255,255,0.2); border-radius: 5px; }
        
        .glass-card { background: white; border: none; border-radius: 20px; box-shadow: 0 10px 30px rgba(0,0,0,0.05); }
        
        .btn-add-bank {
            border: 2px dashed #e2e8f0;
            border-radius: 20px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #a3aed1;
            transition: 0.3s;
            height: 100%;
            min-height: 200px;
        }
        .btn-add-bank:hover { background: #f8fafc; border-color: #4318FF; color: #4318FF; }

        .account-details th { font-size: 0.75rem; text-transform: uppercase; color: #a3aed1; }
        .account-details td { padding: 15px 0; border-bottom: 1px solid #f1f4f9; }
    </style>
{% endblock %}

{% block body %}
<div class="container-fluid py-4 px-lg-4">

    <div class="d-flex justify-content-between align-items-center mb-5">
        <div>
            <h2 class="fw-bold mb-1" style="color: #2b3674;">Bank Accounts</h2>
            <p class="text-muted mb-0">Manage school bank balances and reconcile statements.</p>
        </div>
        <button class="btn btn-primary rounded-pill px-4 fw-bold shadow-sm" style="background: #4318FF;">
            <i class="fas fa-sync me-2"></i> Fetch Live Balances
        </button>
    </div>

    <div class="row g-4 mb-5">
        {% for acc in accounts %}
        <div class="col-xl-4 col-md-6">
            <div class="card bank-card shadow-sm" style="background: {{ acc.color }};">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <h5 class="fw-bold mb-0">{{ acc.bank }}</h5>
                        <small class="opacity-75">{{ acc.name }}</small>
                    </div>
                    <div class="chip"></div>
                </div>
                <div>
                    <h3 class="fw-bold mb-1">₹ {{ acc.balance|number_format(2) }}</h3>
                    <div class="d-flex justify-content-between align-items-end">
                        <span class="small opacity-75">{{ acc.account_no }}</span>
                        <span class="badge bg-white bg-opacity-25 rounded-pill">{{ acc.status }}</span>
                    </div>
                </div>
                <i class="fas fa-university position-absolute" style="right: -20px; top: -20px; font-size: 8rem; opacity: 0.1;"></i>
            </div>
        </div>
        {% endfor %}

        <div class="col-xl-4 col-md-6">
            <a href="#" class="btn btn-add-bank text-decoration-none">
                <div class="text-center">
                    <i class="fas fa-plus-circle fa-2x mb-2"></i>
                    <div class="fw-bold">Link New Account</div>
                </div>
            </a>
        </div>
    </div>

    <div class="card glass-card p-4">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h5 class="fw-bold mb-0">Reconciliation Statement</h5>
            <div class="d-flex gap-2">
                <button class="btn btn-sm btn-outline-secondary rounded-pill px-3">Filter by Date</button>
                <button class="btn btn-sm btn-outline-primary rounded-pill px-3">Download PDF</button>
            </div>
        </div>

        <div class="table-responsive">
            <table class="table account-details table-borderless align-middle mb-0">
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Transaction Particulars</th>
                        <th>Reference</th>
                        <th class="text-end">Withdrawal</th>
                        <th class="text-end">Deposit</th>
                        <th class="text-end">Balance</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td class="text-muted">22 Apr, 2024</td>
                        <td class="fw-bold text-dark">Bulk Fee Deposit - Grade 10</td>
                        <td><code class="text-primary">DEP-9901</code></td>
                        <td class="text-end">-</td>
                        <td class="text-end text-success fw-bold">+ ₹ 45,000</td>
                        <td class="text-end fw-bold">₹ 8,45,000</td>
                    </tr>
                    <tr>
                        <td class="text-muted">20 Apr, 2024</td>
                        <td class="fw-bold text-dark">Staff Salary - April 2024</td>
                        <td><code class="text-primary">WDL-4402</code></td>
                        <td class="text-end text-danger fw-bold">- ₹ 1,20,000</td>
                        <td class="text-end">-</td>
                        <td class="text-end fw-bold">₹ 8,00,000</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>
{% endblock %}