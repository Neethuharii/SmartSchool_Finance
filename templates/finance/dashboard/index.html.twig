{% extends 'finance/base.html.twig' %}

{% block title %}Finance Command Center{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .card-kpi { border: none; border-radius: 16px; transition: transform 0.3s ease; background: #ffffff; }
        .card-kpi:hover { transform: translateY(-5px); }
        .icon-box { width: 48px; height: 48px; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 1.5rem; }
        .bg-soft-primary { background: rgba(67, 24, 255, 0.1); color: #4318FF; }
        .bg-soft-success { background: rgba(0, 184, 96, 0.1); color: #00B860; }
        .bg-soft-danger { background: rgba(239, 68, 68, 0.1); color: #EF4444; }
        .bg-soft-warning { background: rgba(255, 171, 0, 0.1); color: #FFAB00; }
        .chart-container { background: white; padding: 20px; border-radius: 16px; height: 350px; }
        .quick-action-btn { padding: 15px; border-radius: 12px; border: 1px solid #e2e8f0; background: #fff; text-align: center; color: #2d3748; text-decoration: none; transition: 0.2s; display: block; }
        .quick-action-btn:hover { background: #4318FF; color: white; border-color: #4318FF; }
    </style>
{% endblock %}

{% block body %}
<div class="container-fluid py-4">
    
    <div class="row g-4 mb-4">
        <div class="col-md-3">
            <div class="card card-kpi shadow-sm p-3">
                <div class="d-flex align-items-center">
                    <div class="icon-box bg-soft-primary"><i class="fas fa-file-invoice"></i></div>
                    <div class="ms-3">
                        <small class="text-muted fw-bold">Total Billed</small>
                        <h4 class="mb-0 fw-bold">${{ stats.totalBilled|number_format(0) }}</h4>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card card-kpi shadow-sm p-3">
                <div class="d-flex align-items-center">
                    <div class="icon-box bg-soft-success"><i class="fas fa-hand-holding-usd"></i></div>
                    <div class="ms-3">
                        <small class="text-muted fw-bold">Total Collected</small>
                        <h4 class="mb-0 fw-bold text-success">${{ stats.totalPaid|number_format(0) }}</h4>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card card-kpi shadow-sm p-3">
                <div class="d-flex align-items-center">
                    <div class="icon-box bg-soft-danger"><i class="fas fa-exclamation-circle"></i></div>
                    <div class="ms-3">
                        <small class="text-muted fw-bold">Total Overdue</small>
                        <h4 class="mb-0 fw-bold text-danger">${{ stats.totalBalance|number_format(0) }}</h4>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card card-kpi shadow-sm p-3">
                <div class="d-flex align-items-center">
                    <div class="icon-box bg-soft-warning"><i class="fas fa-calendar-check"></i></div>
                    <div class="ms-3">
                        <small class="text-muted fw-bold">Today's Income</small>
                        <h4 class="mb-0 fw-bold text-warning">${{ stats.todayCollection|number_format(0) }}</h4>
                    </div>
                </div>
            </div>
        </div>
    </div>

    {#<div class="row g-4 mb-4">
        <div class="col-lg-8">
            <div class="chart-container shadow-sm">
                <h6 class="fw-bold mb-3"><i class="fas fa-chart-line me-2"></i>Income Trend</h6>
                <canvas id="revenueChart"></canvas>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="chart-container shadow-sm text-center">
                <h6 class="fw-bold mb-3">Revenue by Category</h6>
                <canvas id="categoryChart"></canvas>
            </div>
        </div>
    </div>#}

    <div class="row g-4">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-4 p-4">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h5 class="fw-bold m-0">Recent Invoices</h5>
{#                    <a href="{{ path('admin_invoice_list') }}" class="btn btn-sm btn-link text-primary p-0 fw-bold">View All</a>#}
                </div>
                <div class="table-responsive">
                    <table class="table table-borderless align-middle">
                        <thead class="text-muted small text-uppercase">
                            <tr>
                                <th>Student</th>
                                <th>Category</th>
                                <th>Amount</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for invoice in recentInvoices %}
                            <tr>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <div class="rounded-circle bg-light p-2 me-3"><i class="fas fa-user text-muted"></i></div>
                                        <span class="fw-bold">{{ invoice.student.firstName }} {{ invoice.student.lastName }}</span>
                                    </div>
                                </td>
                                <td><span class="badge bg-light text-dark">{{ invoice.feeCategory.name }}</span></td>
                                <td class="fw-bold text-dark">${{ invoice.totalAmount|number_format(2) }}</td>
                                <td>
                                    {% if invoice.status == 'Paid' %}
                                        <span class="text-success small fw-bold">Paid</span>
                                    {% else %}
                                        <span class="text-danger small fw-bold">Unpaid</span>
                                    {% endif %}
                                </td>
                            </tr>
                            {% else %}
                            <tr><td colspan="4" class="text-center text-muted">No transactions found</td></tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
        
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm rounded-4 p-4">
                <h5 class="fw-bold mb-4">Quick Actions</h5>
                <div class="d-grid gap-3">
                    <a href="{{ path('finance_invoice_new') }}" class="quick-action-btn"><i class="fas fa-plus me-2"></i> Create Single Invoice</a>
                    <a href="{{ path('finance_bulk_invoice') }}" class="quick-action-btn"><i class="fas fa-mail-bulk me-2"></i> Generate Class Bill</a>
                    <a href="{{path('finance_collect_payment')}}" class="quick-action-btn text-success border-success-subtle"><i class="fas fa-hand-holding-usd me-2"></i> Collect Payment</a>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        // Dynamic Category Chart Data from PHP
        const categoryLabels = [{% for item in categoryData %}"{{ item.name }}",{% endfor %}];
        const categoryTotals = [{% for item in categoryData %}{{ item.total }},{% endfor %}];

        const ctxCat = document.getElementById('categoryChart').getContext('2d');
        new Chart(ctxCat, {
            type: 'doughnut',
            data: {
                labels: categoryLabels,
                datasets: [{
                    data: categoryTotals,
                    backgroundColor: ['#4318FF', '#00B860', '#FFAB00', '#EF4444', '#7B61FF'],
                    borderWidth: 0
                }]
            },
            options: { cutout: '75%', maintainAspectRatio: false }
        });

        // (Static for now) Trend Chart
        const ctxRev = document.getElementById('revenueChart').getContext('2d');
        new Chart(ctxRev, {
            type: 'line',
            data: {
                labels: ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun'],
                datasets: [{
                    label: 'Collection Trend',
                    data: [5000, 10000, 8000, 15000, 12000, {{ stats.todayCollection }}],
                    borderColor: '#4318FF',
                    tension: 0.4,
                    fill: true,
                    backgroundColor: 'rgba(67, 24, 255, 0.05)'
                }]
            },
            options: { maintainAspectRatio: false }
        });
    </script>
{% endblock %}