{% extends 'finance/base.html.twig' %}

{% block title %}Manage Fee Categories{% endblock %}

{% block body %}
<div class="container-fluid py-4">
    
    {# 1. HEADER SECTION #}
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h4 class="fw-bold text-dark m-0">Fee Categories</h4>
            <p class="text-muted small m-0">Define and manage various school fee types</p>
        </div>
        <button class="btn btn-primary px-4 py-2 rounded-3 fw-bold shadow-sm" 
                type="button" data-bs-toggle="collapse" data-bs-target="#addCategoryCollapse" 
                style="background: #4318FF; border: none;">
            <i class="fas fa-plus me-2"></i> Add New Category
        </button>
    </div>

    {# 2. COLLAPSIBLE ADD FORM #}
    <div class="collapse mb-4" id="addCategoryCollapse">
        <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
            <div class="card-header bg-light border-0 py-3">
                <h6 class="m-0 fw-bold"><i class="fas fa-edit me-2 text-primary"></i>New Category Details</h6>
            </div>
            <div class="card-body p-4">
                <form method="POST" class="row g-3">
                    <div class="col-md-4">
                        <label class="form-label small fw-bold text-uppercase">Category Name</label>
                        <input type="text" name="name" class="form-control custom-input" placeholder="e.g. Tuition Fee" required>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label small fw-bold text-uppercase">Description</label>
                        <input type="text" name="description" class="form-control custom-input" placeholder="What is this fee for?">
                    </div>
                    <div class="col-md-2 d-flex align-items-end">
                        <button type="submit" class="btn btn-primary w-100 py-2 fw-bold" style="background: #4318FF; border: none;">
                            Save
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    {# 3. CATEGORY LIST CARDS #}
    <div class="card border-0 shadow-sm rounded-4">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4 py-3 text-muted small text-uppercase fw-bold">Fee Name</th>
                        <th class="py-3 text-muted small text-uppercase fw-bold">Description</th>
                        <th class="py-3 text-muted small text-uppercase fw-bold text-center">Status</th>
                        <th class="pe-4 py-3 text-muted small text-uppercase fw-bold text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for category in categories %}
                        <tr>
                            <td class="ps-4">
                                <div class="d-flex align-items-center">
                                    <div class="icon-shape bg-soft-primary rounded-3 me-3 text-primary">
                                        <i class="fas fa-tag"></i>
                                    </div>
                                    <span class="fw-bold text-dark">{{ category.name }}</span>
                                </div>
                            </td>
                            <td class="text-muted">{{ category.description }}</td>
                            <td class="text-center">
                                <div class="form-check form-switch d-inline-block">
                                    <input class="form-check-input" type="checkbox" disabled {{ category.isActive ? 'checked' : '' }}>
                                </div>
                                <span class="d-block small {{ category.isActive ? 'text-success' : 'text-danger' }} fw-bold">
                                    {{ category.isActive ? 'ACTIVE' : 'INACTIVE' }}
                                </span>
                            </td>
                            <td class="pe-4 text-end">
                                <div class="btn-group shadow-sm rounded-3">
                                    <button class="btn btn-white btn-sm px-3" data-bs-toggle="modal" data-bs-target="#editModal{{ category.id }}" title="Edit">
                                        <i class="fas fa-pen text-primary"></i>
                                    </button>
                                    <form method="POST" action="{{ path('admin_fee_category_delete', {'id': category.id}) }}" 
                                          onsubmit="return confirm('Are you sure?');" class="d-inline">
                                        <button type="submit" class="btn btn-white btn-sm px-3" title="Delete">
                                            <i class="fas fa-trash-alt text-danger"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>

                        
                        <div class="modal fade" id="editModal{{ category.id }}" tabindex="-1" aria-hidden="true">
                            <div class="modal-dialog modal-dialog-centered">
                                <div class="modal-content border-0 shadow-lg rounded-4">
                                    <form method="POST" action="{{ path('admin_fee_category_edit', {'id': category.id}) }}">
                                        <div class="modal-header border-0 p-4 pb-0">
                                            <h5 class="fw-bold m-0">Update Category</h5>
                                            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                        </div>
                                        <div class="modal-body p-4">
                                            <div class="mb-3">
                                                <label class="form-label small fw-bold">Name</label>
                                                <input type="text" name="name" class="form-control custom-input" value="{{ category.name }}" required>
                                            </div>
                                            <div class="mb-3">
                                                <label class="form-label small fw-bold">Description</label>
                                                <textarea name="description" class="form-control custom-input" rows="2">{{ category.description }}</textarea>
                                            </div>
                                            <div class="form-check form-switch p-0 ms-4">
                                                <input class="form-check-input" type="checkbox" name="is_active" value="1" {{ category.isActive ? 'checked' : '' }}>
                                                <label class="form-check-label small fw-bold ms-2">Enabled</label>
                                            </div>
                                        </div>
                                        <div class="modal-footer border-0 p-4 pt-0">
                                            <button type="button" class="btn btn-light rounded-3 px-4" data-bs-dismiss="modal">Cancel</button>
                                            <button type="submit" class="btn btn-primary rounded-3 px-4" style="background: #4318FF; border:none;">Update Changes</button>
                                        </div>
                                    </form>
                                </div>
                            </div>
                        </div>
                    {% else %}
                        <tr>
                            <td colspan="4" class="text-center py-5">
                                <img src="https://cdn-icons-png.flaticon.com/512/7486/7486744.png" width="80" class="opacity-25 mb-3">
                                <p class="text-muted">No fee categories found. Start by adding one!</p>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
    .bg-soft-primary { background: rgba(67, 24, 255, 0.08); }
    .icon-shape {
        width: 40px;
        height: 40px;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    .custom-input {
        background: #f8f9fa;
        border: 2px solid #f1f3f5;
        border-radius: 10px;
        padding: 10px 15px;
        transition: 0.3s;
    }
    .custom-input:focus {
        background: #fff;
        border-color: #4318FF;
        box-shadow: none;
    }
    .btn-white {
        background: white;
        border: 1px solid #edf2f7;
    }
    .btn-white:hover {
        background: #f8f9fa;
    }
    .table-hover tbody tr:hover {
        background-color: rgba(67, 24, 255, 0.02);
    }
</style>
{% endblock %}