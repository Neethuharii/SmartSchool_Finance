{% extends 'finance/base.html.twig' %}

{% block title %}Faculty Payroll Registry | Arbor Finance{% endblock %}

{% block stylesheets %}
{{ parent() }}

<style>
    :root {
        --nordic-bg: #faf9f6;
        --nordic-card: #ffffff;
        --nordic-ink: #1c1c1c;
        --nordic-muted: #7d7c7a;
        --nordic-border: #e6e5e2;
        
        --nordic-success: #16a34a; /* Crisp Green for Paid */
        --nordic-danger: #dc2626;  /* Crimson Red for Pending */
    }

    body {
        background-color: var(--nordic-bg) !important;
        color: var(--nordic-ink);
        font-family: 'Inter', system-ui, sans-serif;
        letter-spacing: -0.1px;
    }

    .editorial-title {
        font-family: 'Playfair Display', 'Georgia', serif;
        font-size: 32px;
        font-weight: 700;
        color: var(--nordic-ink);
    }

    /* MATTE FLAT CONTAINERS */
    .nordic-header-panel {
        background: var(--nordic-card);
        border: 1px solid var(--nordic-border);
        border-radius: 16px;
        padding: 35px;
        margin-bottom: 25px;
    }

    .nordic-card {
        background: var(--nordic-card);
        border: 1px solid var(--nordic-border);
        border-radius: 16px;
        padding: 40px;
        box-shadow: 0 4px 20px rgba(0,0,0,0.01);
    }

    /* MINIMALIST FLAT TABLE */
    .table-nordic {
        width: 100%;
        border-collapse: collapse;
    }

    .table-nordic thead th {
        color: var(--nordic-muted);
        font-size: 11px;
        text-transform: uppercase;
        letter-spacing: 1px;
        font-weight: 700;
        border-bottom: 1px solid var(--nordic-ink);
        padding: 15px 10px;
    }

    .table-nordic tbody td {
        padding: 22px 10px;
        border-bottom: 1px solid var(--nordic-border);
        font-size: 14px;
    }

    .table-nordic tbody tr:last-child td {
        border-bottom: none;
    }

    /* TYPE-BASED STATUS INDICATORS */
    .nordic-indicator {
        font-size: 13px;
        font-weight: 700;
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }
    .indicator-paid { color: var(--nordic-success); }
    .indicator-pending { color: var(--nordic-danger); }

    /* TEXT BUTTONS */
    .btn-nordic-pay {
        background: var(--nordic-ink);
        color: var(--nordic-bg);
        border: none;
        padding: 8px 20px;
        border-radius: 8px;
        font-size: 13px;
        font-weight: 600;
        transition: opacity 0.2s;
    }

    .btn-nordic-pay:hover { opacity: 0.85; }

    .btn-nordic-slip {
        background: transparent;
        color: var(--nordic-ink);
        border: 1px solid var(--nordic-ink);
        padding: 8px 20px;
        border-radius: 8px;
        font-size: 13px;
        font-weight: 600;
        transition: background 0.2s;
    }

    .btn-nordic-slip:hover { background: var(--nordic-bg); }

    /* STUDIO DIALOG MODALS */
    .modal-nordic-content {
        background: var(--nordic-card) !important;
        border: 1px solid var(--nordic-border) !important;
        border-radius: 16px !important;
        color: var(--nordic-ink);
    }

    .nordic-input {
        border: 1px solid var(--nordic-border) !important;
        background-color: var(--nordic-bg) !important;
        color: var(--nordic-ink) !important;
        border-radius: 8px !important;
        padding: 12px !important;
    }

    .nordic-input:focus {
        border-color: var(--nordic-ink) !important;
        box-shadow: none !important;
    }

    /* --- SUCCESS ANIMATION (SVG BASED) --- */
    .success-animation { margin: 10px auto 25px; }
    
    .checkmark {
        width: 80px; height: 80px;
        border-radius: 50%;
        display: block;
        stroke-width: 2;
        stroke: #4CAF50;
        stroke-miterlimit: 10;
        box-shadow: inset 0px 0px 0px #4CAF50;
        animation: fill .4s ease-in-out .4s forwards, scale .3s ease-in-out .9s both;
        position: relative;
        margin: 0 auto;
    }

    .checkmark__circle {
        stroke-dasharray: 166;
        stroke-dashoffset: 166;
        stroke-width: 2;
        stroke-miterlimit: 10;
        stroke: #4CAF50;
        fill: none;
        animation: stroke 0.6s cubic-bezier(0.65, 0, 0.45, 1) forwards;
    }

    .checkmark__check {
        transform-origin: 50% 50%;
        stroke-dasharray: 48;
        stroke-dashoffset: 48;
        animation: stroke 0.3s cubic-bezier(0.65, 0, 0.45, 1) 0.8s forwards;
    }

    @keyframes stroke { 100% { stroke-dashoffset: 0; } }
    @keyframes scale { 0%, 100% { transform: none; } 50% { transform: scale3d(1.1, 1.1, 1); } }
    @keyframes fill { 100% { box-shadow: inset 0px 0px 0px 30px #fff; } }

    .info-box-custom { 
        background-color: #ffffff; 
        border: 1px solid #eee; 
        border-radius: 15px;
        max-width: 320px;
        margin: 0 auto;
    }
    
    .btn-dashboard {
        background-color: #1a1d21;
        color: white;
        border: none;
        padding: 12px;
        font-weight: 600;
        transition: all 0.2s;
    }
    .btn-dashboard:hover {
        background-color: #000;
        color: #fff;
    }

    /* ===================================
        CONTEXT PRINT HOOK OVERRIDES
    ==================================== */
    .print-buffer-injection-point {
        display: none;
    }

    @media print {
        body, html {
            background: #ffffff !important;
            color: #000000 !important;
        }
        #arbor-portal-viewport, .modal, .modal-backdrop, .alert {
            display: none !important;
        }
        .print-buffer-injection-point {
            display: block !important;
        }
        .editorial-slip-page {
            page-break-after: always;
            width: 100%;
            padding: 20mm;
            font-family: 'Times New Roman', Times, serif;
            color: #000;
            background: #fff;
        }
        .editorial-header-rule {
            border-bottom: 2px solid #000;
            padding-bottom: 10px;
            margin-bottom: 30px;
        }
        .editorial-grid-table {
            width: 100%;
            border-collapse: collapse;
            margin: 20px 0;
        }
        .editorial-grid-table td, .editorial-grid-table th {
            padding: 8px;
            border-bottom: 1px solid #1c1c1c;
            font-size: 14px;
        }
    }
</style>
{% endblock %}

{% block body %}
<div id="arbor-portal-viewport">
    <div class="container py-5">

        {# EDITORIAL HEADER #}
        <div class="nordic-header-panel d-flex justify-content-between align-items-center">
            <div>
                <h1 class="editorial-title">Faculty Payroll</h1>
                <p class="sub-title text-muted m-0">Monthly Salary Statement Dashboard &bull; <strong>{{ currentMonth }}</strong></p>
            </div>
            <div class="text-end d-none d-sm-block">
                <span class="font-monospace text-uppercase small tracking-wider style-muted" style="font-size: 11px; color: var(--nordic-muted);">Registry Scope</span>
                <div class="fw-bold fs-5 mt-1">{{ teachers|length }} Profiles Loaded</div>
            </div>
        </div>

        {% for message in app.flashes('batch_success') %}
            <div class="alert alert-dark bg-dark text-white border-0 rounded-3 px-4 py-3 mb-4">
                <i class="fas fa-feather-pointed me-2"></i> {{ message }}
            </div>
        {% endfor %}

        {# MAIN FLAT REGISTER #}
        <div class="nordic-card">
            <div class="table-responsive">
                <table class="table table-nordic align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Teacher Assignment</th>
                            <th>Contract Base</th>
                            <th>Status</th>
                            <th class="text-end">Administrative Routing</th>
                        </tr>
                    </thead>
                    <tbody>
                    {% for teacher in teachers %}
                        {% set isPaid = teacher.id in paidTeacherIds %}
                        <tr>
                            <td>
                                <div class="fw-bold" style="color: var(--nordic-ink);">{{ teacher.firstName }} {{ teacher.lastName }}</div>
                                <small class="text-muted font-monospace" style="font-size: 11px;">{{ teacher.staffId|default('SYS-ID-' ~ teacher.id) }}</small>
                            </td>
                            <td class="fw-bold">
                                ${{ teacher.baseSalary|default(4500)|number_format(2) }}
                            </td>
                            <td>
                                {% if isPaid %}
                                    <span class="nordic-indicator indicator-paid">
                                        <i class="fas fa-circle-check"></i> Paid
                                    </span>
                                {% else %}
                                    <span class="nordic-indicator indicator-pending">
                                        <i class="fas fa-circle-exclamation"></i> Pending
                                    </span>
                                {% endif %}
                            </td>
                            <td class="text-end">
                                {% if not isPaid %}
                                    <button class="btn-nordic-pay" data-bs-toggle="modal" data-bs-target="#payModal{{ teacher.id }}">
                                        Issue Funds
                                    </button>
                                {% else %}
                                    <button class="btn-nordic-slip" onclick="executeIsolatedPrintLoop('paper-slip-target-{{ teacher.id }}')">
                                        View Statement
                                    </button>
                                {% endif %}
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="4" class="text-center text-muted py-5">No registered teachers matched application framework definitions.</td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

{# ACTIVE INJECTION NODE BUFFER #}
<div class="print-buffer-injection-point" id="print-buffer-injection-point"></div>

{# DISBURSEMENT REGISTER DIALOGS #}
{% for teacher in teachers %}
<div class="modal fade" id="payModal{{ teacher.id }}" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <form method="POST" action="{{ path('finance_payroll') }}" class="modal-content modal-nordic-content p-4">
            <div class="modal-header border-0 pb-0">
                <h5 class="fw-bold m-0 text-dark">Authorize Financial Statement</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body py-4">
                <input type="hidden" name="teacher_id" value="{{ teacher.id }}">
                
                <div class="mb-3">
                    <label class="form-label text-muted small fw-bold text-uppercase">Account Beneficiary</label>
                    <input type="text" class="form-control nordic-input fw-bold" value="{{ teacher.firstName }} {{ teacher.lastName }}" readonly>
                </div>
                
                <div class="row g-3">
                    <div class="col-6">
                        <label class="form-label text-muted small fw-bold text-uppercase">Allocation Cycle</label>
                        <input type="text" name="month" class="form-control nordic-input" value="{{ currentMonth }}" readonly>
                    </div>
                    <div class="col-6">
                        <label class="form-label text-muted small fw-bold text-uppercase">Net Remittance</label>
                        <input type="number" step="0.01" name="amount" class="form-control nordic-input fw-bold" value="{{ teacher.baseSalary|default(4500) }}">
                    </div>
                </div>
            </div>
            <div class="modal-footer border-0 pt-0">
                <button type="submit" class="btn btn-nordic-pay w-100 py-2" style="border-radius: 8px;">Approve Remittance File</button>
            </div>
        </form>
    </div>
</div>

{# STANDALONE PRINT ARTIFACT: Houses clean text layout for print actions only #}
<div id="paper-slip-target-{{ teacher.id }}" style="display:none;">
    <div class="editorial-slip-page">
        <div class="editorial-header-rule">
            <h1 style="margin:0; font-weight: normal; font-size: 26px;">ARBOR EDUCATION REGISTRY</h1>
            <p style="margin:5px 0 0; font-style: italic; color:#333;">Official Remittance Advice Note</p>
        </div>
        
        <table class="editorial-grid-table">
            <tr>
                <td style="font-weight: bold; width: 25%;">Employee Profile:</td>
                <td style="width: 25%;">{{ teacher.firstName }} {{ teacher.lastName }}</td>
                <td style="font-weight: bold; width: 25%;">Fiscal Period:</td>
                <td style="width: 25%;">{{ currentMonth }}</td>
            </tr>
            <tr>
                <td style="font-weight: bold;">System reference:</td>
                <td>{{ teacher.staffId|default('SYS-ID-' ~ teacher.id) }}</td>
                <td style="font-weight: bold;">Accounting status:</td>
                <td>FUNDS TRANSFERRED / COMPLETED</td>
            </tr>
        </table>

        <h3 style="margin-top:40px; font-weight: normal; border-bottom:1px solid #000; padding-bottom:5px;">Ledger Breakdown</h3>
        <table class="editorial-grid-table">
            <thead>
                <tr>
                    <th style="text-align: left; font-weight: bold;">Description Allocation</th>
                    <th style="text-align: right; font-weight: bold;">Amount Paid (USD)</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td>Standard Monthly Professional Faculty Base Salary Contract</td>
                    <td style="text-align: right;">${{ teacher.baseSalary|default(4500)|number_format(2) }}</td>
                </tr>
                <tr style="font-weight: bold; font-size: 15px;">
                    <td>Net Core Remittance Disbursed</td>
                    <td style="text-align: right;">${{ teacher.baseSalary|default(4500)|number_format(2) }}</td>
                </tr>
            </tbody>
        </table>

        <div style="margin-top:80px; font-size:12px; text-align:center; font-style: italic; color:#444; border-top: 1px dashed #000; padding-top: 15px;">
            This document confirms that an electronic transfer execution file has been initialized on the system engine server.<br>
            <strong>Official System Record Statement — Verified Security Token Log entry.</strong>
        </div>
    </div>
</div>
{% endfor %}

{# --- GPAY SUCCESS MODAL --- #}
{% if app.session.flashbag.has('payment_success') %}
    <div class="modal fade" id="gpaySuccessModal" tabindex="-1" aria-hidden="true" data-bs-backdrop="static">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg rounded-5 text-center p-5" style="background: #ffffff;">
                
                <div class="success-animation">
                    <svg class="checkmark" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 52 52">
                        <circle class="checkmark__circle" cx="26" cy="26" r="25" fill="none"/>
                        <path class="checkmark__check" fill="none" d="M14.1 27.2l7.1 7.2 16.7-16.8"/>
                    </svg>
                </div>

                <h2 class="fw-bold text-dark">Payment Successful!</h2>
                
                {% set names = app.flashes('paid_teacher_name') %}
                <p class="text-muted fs-6 mb-4">
                    Salary has been disbursed to <br>
                    <strong class="text-dark">{{ names|first }}</strong>
                </p>
                
                <div class="info-box-custom p-3 mb-4 text-start">
                    <div class="d-flex align-items-center mb-2">
                        <i class="fas fa-file-invoice text-primary me-3"></i>
                        <span class="small text-primary fw-bold">Digital Payslip Generated</span>
                    </div>
                    <div class="d-flex align-items-center">
                        <i class="fas fa-bell text-success me-3"></i>
                        <span class="small text-success fw-bold">Teacher Portal Notified</span>
                    </div>
                </div>

                <button type="button" class="btn btn-dashboard w-100 rounded-pill" data-bs-dismiss="modal">
                    Back to Dashboard
                </button>
            </div>
        </div>
    </div>
{% endif %}
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
    document.addEventListener('DOMContentLoaded', function() {
        var gpayModalEl = document.getElementById('gpaySuccessModal');
        if (gpayModalEl) {
            var gpayModal = new bootstrap.Modal(gpayModalEl);
            gpayModal.show();
        }
    });

    // CLONES HIDDEN DATA NODES DIRECTLY INTO THE PRIMARY PRINT WINDOW STREAM
    function executeIsolatedPrintLoop(sourceTargetIdString) {
        var sourceDataMarkup = document.getElementById(sourceTargetIdString).innerHTML;
        var systemicBufferPoint = document.getElementById('print-buffer-injection-point');
        
        // Inject components into memory tree paths natively
        systemicBufferPoint.innerHTML = sourceDataMarkup;
        
        // Open OS standard printer driver setup dialogues
        window.print();
        
        // Purge target injection arrays immediately upon completion
        systemicBufferPoint.innerHTML = "";
    }
</script>
{% endblock %}