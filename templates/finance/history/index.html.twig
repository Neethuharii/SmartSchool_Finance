{% extends 'finance/base.html.twig' %}

{% block title %}Payment History - Financial Portal{% endblock %}

{% block body %}
<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-dark mb-1">Payment History</h2>
            <p class="text-muted small">Overview of all received tuition fees and charges.</p>
        </div>
        <div class="d-flex gap-2">
            <button onclick="window.print()" class="btn btn-outline-primary rounded-3 px-3">
                <i class="fas fa-file-export me-2"></i>Export CSV
                ></a>
            </button>
            <a href="{{ path('finance_collect_payment') }}" class="btn btn-primary rounded-3 px-4 shadow-sm" style="background: #4318FF; border: none;">
                <i class="fas fa-plus me-2"></i>New Payment
            </a>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="card-header bg-white border-0 p-4">
            <div class="input-group bg-light rounded-3 px-2">
                <span class="input-group-text bg-transparent border-0"><i class="fas fa-search text-muted"></i></span>
                <input type="text" id="historySearch" class="form-control bg-transparent border-0 py-2" placeholder="Search by Student Name or Reference...">
            </div>
        </div>
        
        <div class="table-responsive">
            <table class="table align-middle table-hover mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4 text-muted small fw-bold">TRANSACTION ID</th>
                        <th class="text-muted small fw-bold">STUDENT</th>
                        <th class="text-muted small fw-bold">CLASS</th>
                        <th class="text-muted small fw-bold">METHOD</th>
                        <th class="text-muted small fw-bold">DATE</th>
                        <th class="text-muted small fw-bold text-end pe-4">AMOUNT</th>
                    </tr>
                </thead>
                <tbody id="historyTableBody">
                    {% for payment in payments %}
                        <tr>
                            <td class="ps-4">
                                <span class="fw-bold text-uppercase small text-primary">#PAY-{{ payment.id|format("%05d") }}</span>
                            </td>
                            <td>
                                <div class="fw-bold text-dark">{{ payment.student.firstName }} {{ payment.student.lastName }}</div>
                                <div class="text-muted small">ID: {{ payment.student.admissionNo }}</div>
                            </td>
                            <td>
                                <span class="badge bg-light text-dark border">
                                    {{ payment.student.section ? payment.student.section.academicClass.name : 'Unassigned' }}
                                </span>
                            </td>
                            <td>
                                <div class="d-flex align-items-center">
                                    {% if payment.method == 'Cash' %}
                                        <i class="fas fa-money-bill-wave text-success me-2"></i>
                                    {% elseif payment.method == 'Bank Transfer' %}
                                        <i class="fas fa-university text-primary me-2"></i>
                                    {% else %}
                                        <i class="fas fa-credit-card text-info me-2"></i>
                                    {% endif %}
                                    {{ payment.method }}
                                </div>
                            </td>
                            <td>
                                <div class="text-dark fw-semibold">{{ payment.paidAt|date('d M, Y') }}</div>
                                <div class="text-muted small">{{ payment.paidAt|date('h:i A') }}</div>
                            </td>
                            <td class="text-end pe-4">
                                <h6 class="fw-bold text-success mb-0">+ ${{ payment.amount|number_format(2) }}</h6>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="6" class="text-center py-5">
                                <img src="https://cdn-icons-png.flaticon.com/512/4076/4076432.png" width="80" class="mb-3 opacity-25">
                                <p class="text-muted">No payments found in the records.</p>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
    .table-hover tbody tr:hover { background-color: rgba(67, 24, 255, 0.02); }
    .card { background: #ffffff; }
    thead th { letter-spacing: 0.5px; }
</style>

<script>
    // Simple  search filter
    document.getElementById('historySearch').addEventListener('keyup', function() {
        let value = this.value.toLowerCase();
          // Select all table rows
        let rows = document.querySelectorAll('#historyTableBody tr');
        rows.forEach(row => {
               // Check if row text contains search value
            row.style.display = (row.textContent.toLowerCase().indexOf(value) > -1) ? '' : 'none';
        });
    });
    
    
{#function exportTableToCSV(filename) {
