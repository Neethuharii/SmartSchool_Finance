{% extends 'finance/base.html.twig' %}

{% block title %}Transactions{% endblock %}

{% block body %}

<div class="container-fluid py-4">

    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>
            <h3 class="fw-bold">Transactions</h3>
            <p class="text-muted">Income & Expenses</p>
        </div>

        <div class="d-flex gap-2 align-items-center">

            <a href="{{ path('finance_transactions') }}"
               class="btn btn-light {{ not app.request.query.get('type') ? 'active' : '' }}">
                All
            </a>

            <a href="{{ path('finance_transactions', {type:'income'}) }}"
               class="btn btn-light {{ app.request.query.get('type')=='income' ? 'active' : '' }}">
                Income
            </a>

            <a href="{{ path('finance_transactions', {type:'expense'}) }}"
               class="btn btn-light {{ app.request.query.get('type')=='expense' ? 'active' : '' }}">
                Expense
            </a>

            {# BUTTON TRIGGER MODAL #}
            <button class="btn btn-primary ms-3"
                    data-bs-toggle="modal"
                    data-bs-target="#addTransactionModal">
                + New Transaction
            </button>

        </div>

    </div>

    <div class="card p-4">

        <table class="table table-borderless align-middle">

            <thead>
                <tr>
                    <th>Date</th>
                    <th>Title</th>
                    <th>Category</th>
                    <th>Method</th>
                    <th class="text-end">Amount</th>
                </tr>
            </thead>

            <tbody>
                {% for tr in transactions %}
                <tr>
                    <td>{{ tr.date|date('d M Y') }}</td>
                    <td>{{ tr.title }}</td>
                    <td>{{ tr.category }}</td>
                    <td>{{ tr.method }}</td>
                    <td class="text-end fw-bold {{ tr.type == 'INCOME' ? 'text-success' : 'text-danger' }}">
                        {{ tr.type == 'INCOME' ? '+' : '-' }} ₹{{ tr.amount }}
                    </td>
                </tr>
                {% else %}
                <tr>
                    <td colspan="5" class="text-center text-muted py-5">
                        No transactions found
                    </td>
                </tr>
                {% endfor %}
            </tbody>

        </table>

    </div>

</div>

{# ================= MODAL ================= #}
<div class="modal fade" id="addTransactionModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">

        <div class="modal-content border-0 shadow-lg" style="border-radius: 16px;">

            <div class="modal-header">
                <h5 class="fw-bold">Add Transaction</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <form action="{{ path('finance_transaction_quick_add') }}" method="POST">

                <div class="modal-body">

                    {# TYPE #}
                    <div class="mb-3">
                        <label class="form-label fw-bold">Type</label>
                        <select name="type" class="form-select" required>
                            <option value="INCOME">Income</option>
                            <option value="EXPENSE">Expense</option>
                        </select>
                    </div>

                    {# STUDENT (IMPORTANT) #}
                    <div class="mb-3">
                        <label class="form-label fw-bold">Student (Only for Income)</label>
                        <select name="student_id" class="form-select">
                            <option value="">-- Select Student --</option>
                            {% for student in students %}
                                <option value="{{ student.id }}">
                                    {{ student.fullName }}
                                </option>
                            {% endfor %}
                        </select>
                    </div>

                    {# TITLE #}
                    <div class="mb-3">
                        <label class="form-label fw-bold">Title</label>
                        <input type="text" name="title" class="form-control" required>
                    </div>

                    {# AMOUNT #}
                    <div class="mb-3">
                        <label class="form-label fw-bold">Amount</label>
                        <input type="number" step="0.01" name="amount" class="form-control" required>
                    </div>

                    {# METHOD #}
                    <div class="mb-3">
                        <label class="form-label fw-bold">Method</label>
                        <select name="method" class="form-select">
                            <option value="Cash">Cash</option>
                            <option value="Bank">Bank</option>
                        </select>
                    </div>

                    {# CATEGORY (optional) #}
                    <div class="mb-3">
                        <label class="form-label fw-bold">Category</label>
                        <input type="text" name="category" class="form-control">
                    </div>

                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal">
                        Cancel
                    </button>

                    <button type="submit" class="btn btn-primary">
                        Save Transaction
                    </button>
                </div>

            </form>

        </div>
    </div>
</div>

{% endblock %}