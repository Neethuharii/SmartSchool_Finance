{% extends 'admin/dashboard/index.html.twig' %}

{% block title %}Add Academic Year | Admin{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
      
        .custom-input {
            background-color: #f8fafc;
            border: 1px solid #e2e8f0;
            border-radius: 12px;
            padding: 12px 16px;
            color: var(--text-main);
            transition: all 0.2s ease;
            font-size: 0.95rem;
        }

        .custom-input:focus {
            background-color: #ffffff;
            border-color: #868CFF;
            box-shadow: 0 0 0 4px rgba(67, 24, 255, 0.1);
            outline: none;
        }

        .custom-label {
            font-weight: 600;
            color: var(--text-main);
            margin-bottom: 8px;
            font-size: 0.9rem;
        }

        
        .custom-switch .form-check-input {
            width: 3em;
            height: 1.5em;
            cursor: pointer;
        }

        .custom-switch .form-check-input:checked {
            background-color: #05CD99;
            border-color: #05CD99;
        }

        .custom-switch .form-check-label {
            margin-left: 10px;
            padding-top: 4px;
            cursor: pointer;
            font-weight: 600;
            color: var(--text-main);
        }

      
        .btn-back {
            width: 42px;
            height: 42px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            background: white;
            border: 1px solid #e2e8f0;
            border-radius: 50%;
            color: var(--text-muted);
            transition: 0.3s;
            box-shadow: 0 2px 5px rgba(0,0,0,0.02);
        }

        .btn-back:hover {
            color: #4318FF;
            border-color: #4318FF;
            background: #f4f7fe;
            transform: translateX(-3px);
        }
    </style>
{% endblock %}

{% block body %}

<div class="container-fluid py-4 px-lg-4">

    <div class="d-flex align-items-center mb-5 gap-3">
        <a href="{{ path('academic_year_index') }}" class="btn-back text-decoration-none">
            <i class="fas fa-arrow-left"></i>
        </a>
        <div>
            <h2 class="fw-bold mb-0" style="color: var(--text-main);">Create Academic Year</h2>
            <p class="text-muted mb-0">Define a new session for school administration.</p>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-8 col-xl-6">
            <div class="card glass-card p-4 p-md-5">
                
                <form method="POST">
                    
                    <div class="mb-4">
                        <label class="custom-label">
                            <i class="fas fa-graduation-cap text-primary me-2"></i> Session Name
                        </label>
                        <input type="text" name="name" class="form-control custom-input" placeholder="e.g. 2025-2026" required>
                        <div class="form-text text-muted mt-2" style="font-size: 0.8rem;">
                            Use a clear format like "YYYY-YYYY" to avoid confusion.
                        </div>
                    </div>

                    <div class="row mb-4 g-3">
                        <div class="col-md-6">
                            <label class="custom-label">
                                <i class="far fa-calendar-alt text-primary me-2"></i> Start Date
                            </label>
                            <input type="date" name="startDate" class="form-control custom-input" required>
                        </div>
                        
                        <div class="col-md-6">
                            <label class="custom-label">
                                <i class="far fa-calendar-check text-primary me-2"></i> End Date
                            </label>
                            <input type="date" name="endDate" class="form-control custom-input" required>
                        </div>
                    </div>

                    <div class="mb-5 p-3 rounded-3" style="background: #f8fafc; border: 1px solid #e2e8f0;">
                        <div class="form-check form-switch custom-switch d-flex align-items-center mb-0 p-0">
                            <input class="form-check-input ms-0 mt-0" type="checkbox" role="switch" id="isActiveSwitch" name="isActive" checked>
                            <label class="form-check-label" for="isActiveSwitch">
                                Set as Active Session
                            </label>
                        </div>
                        <small class="text-muted d-block mt-2 ms-5">
                            Making this active will automatically apply it to all new fee collections and student enrollments.
                        </small>
                    </div>

                    <hr class="mb-4" style="border-color: #e2e8f0;">

                    <div class="d-flex justify-content-end gap-3">
                        <a href="{{ path('academic_year_index') }}" class="btn btn-light px-4 py-2 rounded-pill fw-bold" style="color: var(--text-muted);">
                            Cancel
                        </a>
                        <button type="submit" class="btn px-5 py-2 rounded-pill fw-bold text-white shadow-sm" style="background: var(--primary-grad); border: none; transition: 0.3s;" onmouseover="this.style.transform='translateY(-2px)'" onmouseout="this.style.transform='translateY(0)'">
                            <i class="fas fa-save me-2"></i> Save Year
                        </button>
                    </div>
                    
                </form>

            </div>
        </div>
        
        <div class="col-lg-4 col-xl-5 d-none d-lg-block">
            <div class="card glass-card p-4 bg-light border-0">
                <h5 class="fw-bold mb-3"><i class="fas fa-lightbulb text-warning me-2"></i> Quick Tip</h5>
                <p class="text-muted text-sm mb-3">
                    The <strong>Active Session</strong> is the default timeline your school operates in. 
                </p>
                <ul class="text-muted small ps-3">
                    <li class="mb-2">Ensure dates do not overlap with previous academic years.</li>
                    <li class="mb-2">Financial reports will automatically filter based on these dates.</li>
                </ul>
            </div>
        </div>
    </div>

</div>

{% endblock %}