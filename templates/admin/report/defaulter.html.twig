{% extends 'admin/dashboard/index.html.twig' %}

{% block title %}Fee Defaulters List{% endblock %}

{% block body %}
<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold" style="color: #2b3674;">Fee Defaulters</h2>
            <p class="text-muted">List of students with outstanding balances.</p>
        </div>
        <button class="btn btn-danger px-4 fw-bold" onclick="window.print()">
            <i class="fas fa-print me-2"></i> Export PDF
        </button>
    </div>

    <div class="glass-card">
        <div class="table-responsive">
            <table class="table custom-table align-middle">
                <thead>
                    <tr>
                        <th>Student Name</th>
                        <th>Admission No.</th>
                        <th>Total Billed</th>
                        <th>Amount Paid</th>
                        <th>Balance Due</th>
                        <th>Status</th>
                     {#   <th class="text-end">Action</th>#}
                    </tr>
                </thead>
                <tbody>
                    {% for invoice in defaulters %}
                        <tr>
                            <td>
                                <div class="fw-bold text-dark">
                                    {{ invoice.student.firstName }} {{ invoice.student.lastName }}
                                </div>
                                <small class="text-muted">{{ invoice.student.section.academicClass.name }}</small>
                            </td>
                            <td>{{ invoice.student.admissionNo }}</td>
                            <td class="fw-bold">${{ invoice.totalAmount|number_format(2) }}</td>
                            <td class="text-success">${{ invoice.paidAmount|number_format(2) }}</td>
                            <td class="text-danger fw-bold">${{ invoice.balanceAmount|number_format(2) }}</td>
                            <td>
                                <span class="badge {% if invoice.status == 'Partial' %}bg-warning{% else %}bg-danger{% endif %}">
                                    {{ invoice.status|upper }}
                                </span>
                            </td>
                           {# <td class="text-end">
                                <a href="#" class="btn btn-sm btn-outline-primary rounded-pill">
                                    Send Reminder
                                </a>
                            </td>#}
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="7" class="text-center py-5">
                                <i class="fas fa-check-circle text-success fs-1 mb-3"></i>
                                <p class="fw-bold">No defaulters found. All accounts are clear!</p>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% endblock %}