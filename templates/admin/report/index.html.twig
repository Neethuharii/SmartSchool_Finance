{% extends 'admin/dashboard/index.html.twig' %}

{% block title %}Revenue Report{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .stats-card {
            background: #ffffff;
            border-radius: 20px;
            padding: 25px;
            box-shadow: 0 10px 30px rgba(112, 144, 176, 0.08);
            border: none;
            transition: transform 0.3s;
        }
        .stats-card:hover { transform: translateY(-5px); }
        .icon-box {
            width: 50px; height: 50px;
            border-radius: 15px;
            display: flex; align-items: center; justify-content: center;
            font-size: 1.5rem;
        }
    </style>
{% endblock %}

{% block body %}
<div class="container-fluid">
    <h2 class="fw-bold mb-4" style="color: #2b3674;">Financial Revenue Report</h2>

    <div class="row g-4 mb-5">
        <div class="col-md-4">
            <div class="stats-card d-flex align-items-center gap-3">
                <div class="icon-box bg-light text-primary"><i class="fas fa-file-invoice-dollar"></i></div>
                <div>
                    <p class="text-muted small mb-0">Total Billed</p>
                    <h3 class="fw-bold mb-0">${{ totalBilled|number_format(2) }}</h3>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="stats-card d-flex align-items-center gap-3">
                <div class="icon-box bg-light text-success"><i class="fas fa-hand-holding-usd"></i></div>
                <div>
                    <p class="text-muted small mb-0">Total Collected</p>
                    <h3 class="fw-bold mb-0 text-success">${{ totalCollected|number_format(2) }}</h3>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="stats-card d-flex align-items-center gap-3">
                <div class="icon-box bg-light text-danger"><i class="fas fa-exclamation-circle"></i></div>
                <div>
                    <p class="text-muted small mb-0">Pending Arrears</p>
                    <h3 class="fw-bold mb-0 text-danger">${{ totalPending|number_format(2) }}</h3>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-12">
            <div class="stats-card">
                <h5 class="fw-bold mb-4">Monthly Collection Trend ({{ "now"|date("Y") }})</h5>
                <canvas id="revenueChart" height="100"></canvas>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        const ctx = document.getElementById('revenueChart').getContext('2d');
        new Chart(ctx, {
            type: 'line',
            data: {
                labels: [{% for data in monthlyRevenue %}"{{ data.month }}",{% endfor %}],
                datasets: [{
                    label: 'Revenue ($)',
                    data: [{% for data in monthlyRevenue %}{{ data.total }},{% endfor %}],
                    borderColor: '#4318FF',
                    backgroundColor: 'rgba(67, 24, 255, 0.1)',
                    fill: true,
                    tension: 0.4
                }]
            },
            options: {
                plugins: { legend: { display: false } },
                scales: { y: { beginAtZero: true, grid: { display: false } }, x: { grid: { display: false } } }
            }
        });
    </script>
{% endblock %}