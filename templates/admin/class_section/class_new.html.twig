{% extends 'admin/dashboard/index.html.twig' %}

{% block title %}Add Class | Admin{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        
        .custom-input {
            background-color: #f8fafc;
            border: 1px solid #e2e8f0;
            border-radius: 12px;
            padding: 12px 16px;
            color: #2b3674;
            transition: all 0.2s ease;
            font-size: 0.95rem;
        }

        .custom-input:focus {
            background-color: #ffffff;
            border-color: #868CFF;
            box-shadow: 0 0 0 4px rgba(67, 24, 255, 0.1);
            outline: none;
        }

        .custom-label {
            font-weight: 600;
            color: #2b3674;
            margin-bottom: 8px;
            font-size: 0.9rem;
        }

        
        .glass-card {
            background: #ffffff;
            border: none;
            border-radius: 20px;
            box-shadow: 0 10px 30px rgba(112, 144, 176, 0.08);
        }

       
        .btn-back {
            width: 42px;
            height: 42px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            background: white;
            border: 1px solid #e2e8f0;
            border-radius: 50%;
            color: #a3aed1;
            transition: 0.3s;
            box-shadow: 0 2px 5px rgba(0,0,0,0.02);
        }

        .btn-back:hover {
            color: #4318FF;
            border-color: #4318FF;
            background: #f4f7fe;
            transform: translateX(-3px);
        }
    </style>
{% endblock %}

{% block body %}

<div class="container-fluid py-4 px-lg-4">

    <div class="d-flex align-items-center mb-5 gap-3">
        <a href="{{ path('admin_class_index') }}" class="btn-back text-decoration-none">
            <i class="fas fa-arrow-left"></i>
        </a>
        <div>
            <h2 class="fw-bold mb-0" style="color: #2b3674;">Add New Class</h2>
            <p class="text-muted mb-0">Register a new academic class or grade level.</p>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-8 col-xl-6">
            <div class="card glass-card p-4 p-md-5">
                
                <form method="POST">
                    
                    <div class="mb-4">
                        <label class="custom-label">
                            <i class="fas fa-layer-group text-primary me-2"></i> Class Name
                        </label>
                        <input type="text" name="name" class="form-control custom-input" placeholder="e.g. Grade 10, Year 1, Kindergarten" required>
                    </div>

                    <div class="mb-5">
                        <label class="custom-label">
                            <i class="fas fa-sort-numeric-down text-primary me-2"></i> Display Order
                        </label>
                        <input type="number" name="orderNo" class="form-control custom-input" placeholder="e.g. 1, 2, 3..." required min="0">
                        <div class="form-text text-muted mt-2" style="font-size: 0.8rem;">
                            Lower numbers appear first in dropdown menus and reports.
                        </div>
                    </div>

                    <hr class="mb-4" style="border-color: #e2e8f0;">

                    <div class="d-flex justify-content-end gap-3">
                        <a href="{{ path('admin_class_index') }}" class="btn btn-light px-4 py-2 rounded-pill fw-bold" style="color: #a3aed1;">
                            Cancel
                        </a>
                        <button type="submit" class="btn px-5 py-2 rounded-pill fw-bold text-white shadow-sm" style="background: linear-gradient(135deg, #4318FF 0%, #868CFF 100%); border: none; transition: 0.3s;" onmouseover="this.style.transform='translateY(-2px)'" onmouseout="this.style.transform='translateY(0)'">
                            <i class="fas fa-save me-2"></i> Save Class
                        </button>
                    </div>
                    
                </form>

            </div>
        </div>

        <div class="col-lg-4 col-xl-5 d-none d-lg-block">
            <div class="card glass-card p-4 bg-light border-0">
                <h5 class="fw-bold mb-3" style="color: #2b3674;">
                    <i class="fas fa-info-circle text-primary me-2"></i> About Ordering
                </h5>
                <p class="text-muted text-sm mb-3">
                    The <strong>Display Order</strong> is crucial for keeping your system organized. It determines how classes are listed across the entire application.
                </p>
                <div class="bg-white p-3 rounded-3 border" style="border-color: #e2e8f0;">
                    <h6 class="fw-bold text-dark mb-2" style="font-size: 0.85rem;">Suggested Format:</h6>
                    <ul class="text-muted small ps-3 mb-0">
                        <li><strong>10</strong> - Grade 1</li>
                        <li><strong>20</strong> - Grade 2</li>
                        <li><strong>30</strong> - Grade 3</li>
                    </ul>
                </div>
                <small class="text-muted mt-3 d-block">
                    <em>Tip: Leaving gaps (10, 20, 30 instead of 1, 2, 3) allows you to easily insert new classes in between later without renumbering everything.</em>
                </small>
            </div>
        </div>
    </div>

</div>

{% endblock %}