{% extends 'admin/dashboard/index.html.twig' %}

{% block title %}Manage Sections | Admin{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
     
        .glass-card {
            background: #ffffff;
            border: none;
            border-radius: 16px;
            box-shadow: 0 5px 20px rgba(112, 144, 176, 0.08);
        }

     
        .custom-input {
            background-color: #f8fafc;
            border: 1px solid #e2e8f0;
            border-radius: 10px;
            padding: 10px 16px;
            color: #2b3674;
            transition: all 0.2s ease;
            font-size: 0.95rem;
        }

        .custom-input:focus {
            background-color: #ffffff;
            border-color: #868CFF;
            box-shadow: 0 0 0 4px rgba(67, 24, 255, 0.1);
            outline: none;
        }

        .custom-label {
            font-weight: 600;
            color: #2b3674;
            margin-bottom: 6px;
            font-size: 0.85rem;
        }

      
        .custom-table th {
            color: #a3aed1;
            font-weight: 600;
            font-size: 0.8rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            border-bottom: 2px solid #f4f7fe;
            padding-bottom: 15px;
            padding-top: 10px;
        }
        
        .custom-table td {
            padding: 16px 10px;
            border-bottom: 1px dashed #e2e8f0;
            color: #2b3674;
            vertical-align: middle;
        }

      
        .table-icon-btn {
            width: 35px;
            height: 35px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border-radius: 8px;
            transition: 0.2s;
            color: #a3aed1;
            background: #f4f7fe;
            border: none;
            text-decoration: none;
        }
        
        .table-icon-btn:hover {
            background: #e9e3ff;
            color: #4318FF;
            transform: translateY(-2px);
        }

        .badge-soft-primary {
            background: #e9e3ff;
            color: #4318FF;
        }
    </style>
{% endblock %}

{% block body %}

<div class="container-fluid py-4 px-lg-4">

    <div class="mb-4">
        <h2 class="fw-bold mb-1" style="color: #2b3674;">Sections</h2>
        <p class="text-muted mb-0">Manage class subdivisions (e.g., A, B, C) and assign them to classes.</p>
    </div>

    <div class="card glass-card p-4 mb-5 border-start border-4 border-primary" style="border-color: #4318FF !important;">
        <h5 class="fw-bold mb-4" style="color: #2b3674;"><i class="fas fa-plus-circle text-primary me-2"></i> Quick Add Section</h5>
        
        <form method="POST" action="{{ path('admin_section_new') }}">
            <div class="row align-items-end g-3">
                
                <div class="col-md-5">
                    <label class="custom-label">Section Name</label>
                    <input type="text" name="name" class="form-control custom-input" placeholder="e.g. A, B, Science, Arts" required>
                </div>

                <div class="col-md-5">
                    <label class="custom-label">Assign to Class</label>
                    <select name="class_id" class="form-select custom-input" required>
                        <option value="" disabled selected>Select a class...</option>
                        {% for class in classes %}
                            <option value="{{ class.id }}">{{ class.name }}</option>
                        {% endfor %}
                    </select>
                </div>

                <div class="col-md-2">
                    <button type="submit" class="btn w-100 py-2 fw-bold text-white shadow-sm" style="background: linear-gradient(135deg, #4318FF 0%, #868CFF 100%); border: none; border-radius: 10px; transition: 0.3s;" onmouseover="this.style.transform='translateY(-2px)'" onmouseout="this.style.transform='translateY(0)'">
                        Add Section
                    </button>
                </div>

            </div>
        </form>
    </div>

    <div class="card glass-card p-4">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h5 class="fw-bold mb-0" style="color: #2b3674;">Existing Sections</h5>
            <span class="badge bg-light text-dark border">{{ sections|length }} Total</span>
        </div>

        <div class="table-responsive">
            <table class="table custom-table table-borderless align-middle mb-0">
                <thead>
                    <tr>
                        <th width="10%">ID</th>
                        <th width="35%">Section Name</th>
                        <th width="35%">Parent Class</th>
                        <th width="20%" class="text-end">Actions</th>
                    </tr>
                </thead>

                <tbody>
                    {% for section in sections %}
                        <tr>
                            <td class="text-muted fw-semibold">
                                #{{ section.id }}
                            </td>
                            
                            <td>
                                <div class="d-flex align-items-center">
                                    <div class="bg-light rounded-circle d-flex justify-content-center align-items-center me-3" style="width: 35px; height: 35px;">
                                        <i class="fas fa-project-diagram" style="color: #4318FF; font-size: 0.85rem;"></i>
                                    </div>
                                    <span class="fw-bold text-dark fs-6">Section {{ section.name }}</span>
                                </div>
                            </td>
                            
                            <td>
                                <span class="badge badge-soft-primary px-3 py-2 rounded-pill">
                                    <i class="fas fa-layer-group me-1"></i> {{ section.schoolClass.name }}
                                </span>
                            </td>

                            <td class="text-end">
                                <div class="d-flex justify-content-end gap-2">
                                    <a href="#" class="table-icon-btn" title="Edit Section">
                                        <i class="fas fa-pen"></i>
                                    </a>
                                    <a href="#" class="table-icon-btn text-danger" title="Delete Section" onmouseover="this.style.background='#feecea'" onmouseout="this.style.background='#f4f7fe'">
                                        <i class="fas fa-trash"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="4">
                                <div class="text-center py-5">
                                    <div class="d-inline-flex align-items-center justify-content-center bg-light rounded-circle mb-3" style="width: 60px; height: 60px;">
                                        <i class="fas fa-sitemap text-muted fs-3"></i>
                                    </div>
                                    <h5 class="fw-bold text-dark mb-1">No Sections Found</h5>
                                    <p class="text-muted mb-0">Use the form above to add your first class section.</p>
                                </div>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

</div>

{% endblock %}