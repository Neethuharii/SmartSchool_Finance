{% extends 'admin/dashboard/index.html.twig' %}

{% block title %}Admin Dashboard - Arbor Finance{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
      
        .glass-card {
            background: #ffffff;
            border: none;
            border-radius: 20px;
            box-shadow: 0 10px 30px rgba(112, 144, 176, 0.08);
            transition: all 0.3s ease;
        }

        .kpi-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 15px 35px rgba(112, 144, 176, 0.15);
        }

        .icon-shape {
            width: 56px;
            height: 56px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 50%;
            color: white;
            font-size: 1.4rem;
            box-shadow: 0 4px 15px rgba(0,0,0,0.1);
        }

        .bg-grad-primary { background: linear-gradient(135deg, #4318FF 0%, #868CFF 100%); }
        .bg-grad-success { background: linear-gradient(135deg, #05CD99 0%, #43E9A4 100%); }
        .bg-grad-danger { background: linear-gradient(135deg, #EE5D50 0%, #FF928A 100%); }
        .bg-grad-warning { background: linear-gradient(135deg, #FFCE20 0%, #FFE587 100%); }

        .action-btn {
            border-radius: 12px;
            padding: 12px 20px;
            font-weight: 600;
            transition: 0.2s;
            border: none;
            display: flex;
            align-items: center;
        }
        
        .action-btn-primary { background: #e9e3ff; color: #4318FF; }
        .action-btn-primary:hover { background: #4318FF; color: white; transform: scale(1.02); }
        
        .action-btn-success { background: #e0faf1; color: #05CD99; }
        .action-btn-success:hover { background: #05CD99; color: white; transform: scale(1.02); }
        
        .action-btn-warning { background: #fff8dd; color: #e6b400; }
        .action-btn-warning:hover { background: #FFCE20; color: white; transform: scale(1.02); }

      
        .custom-table th {
            color: #a3aed1;
            font-weight: 600;
            font-size: 0.85rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            border-bottom: 2px solid #f4f7fe;
            padding-bottom: 15px;
        }
        
        .custom-table td {
            padding: 15px 10px;
            border-bottom: 1px dashed #e2e8f0;
            color: #2b3674;
            vertical-align: middle;
        }

        .status-badge {
            padding: 6px 14px;
            border-radius: 30px;
            font-size: 0.8rem;
            font-weight: 700;
        }
        
        .badge-soft-success { background: #e0faf1; color: #05CD99; }
        .badge-soft-danger { background: #feecea; color: #EE5D50; }
        .badge-soft-pending { background: #f4f7fe; color: #a3aed1; }
        
    </style>
    
{% endblock %}

{% block body %}
<div class="container-fluid p-0">

    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4 gap-3">
        <div>
            <h2 class="fw-bold mb-1" style="color: #2b3674;">Dashboard</h2>
            <p class="text-muted mb-0">Welcome back! Here is today's financial summary.</p>
        </div>
        <div class="glass-card px-4 py-2 d-flex align-items-center w-auto shadow-sm">
            <i class="far fa-calendar-alt me-2" style="color: #4318FF;"></i>
            <span class="fw-bold text-muted">{{ "now"|date("D, d M Y") }}</span>
        </div>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-xl-3 col-sm-6">
            <div class="card glass-card kpi-card h-100 p-3">
                <div class="card-body d-flex align-items-center">
                    <div class="icon-shape bg-grad-primary me-3">
                        <i class="fas fa-user-graduate"></i>
                    </div>
                    <div>
                        <h6 class="text-muted mb-1" style="font-size: 0.85rem;">Total Students</h6>
                        <h3 class="fw-bold mb-0 text-dark">{{ totalStudents ?? 0 }}</h3>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-sm-6">
            <div class="card glass-card kpi-card h-100 p-3">
                <div class="card-body d-flex align-items-center">
                    <div class="icon-shape bg-grad-success me-3">
                        <i class="fas fa-indian-rupee-sign"></i>
                    </div>
                    <div>
                        <h6 class="text-muted mb-1" style="font-size: 0.85rem;">Total Income</h6>
                        <h3 class="fw-bold mb-0 text-dark">₹ {{ totalIncome is defined ? totalIncome|number_format(2) : '0.00' }}</h3>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-sm-6">
            <div class="card glass-card kpi-card h-100 p-3">
                <div class="card-body d-flex align-items-center">
                    <div class="icon-shape bg-grad-danger me-3">
                        <i class="fas fa-exclamation-circle"></i>
                    </div>
                    <div>
                        <h6 class="text-muted mb-1" style="font-size: 0.85rem;">Pending Fees</h6>
                        <h3 class="fw-bold mb-0 text-danger">₹ {{ pendingFees is defined ? pendingFees|number_format(2) : '0.00' }}</h3>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-sm-6">
            <div class="card glass-card kpi-card h-100 p-3">
                <div class="card-body d-flex align-items-center">
                    <div class="icon-shape bg-grad-warning me-3">
                        <i class="fas fa-wallet"></i>
                    </div>
                    <div>
                        <h6 class="text-muted mb-1" style="font-size: 0.85rem;">Total Expenses</h6>
                        <h3 class="fw-bold mb-0 text-dark">₹ {{ totalExpenses is defined ? totalExpenses|number_format(2) : '0.00' }}</h3>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-8">
            <div class="card glass-card h-100 p-4">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h5 class="fw-bold mb-0 text-dark">Financial Analytics</h5>
                    {#<select class="form-select border-0 bg-light text-muted fw-bold w-auto" style="border-radius: 10px;">
                        <option>This Year</option>
                        <option>Last Year</option>
                    </select>#}
                </div>
                <div class="card-body p-0" style="position: relative; height: 300px;">
                    <canvas id="financeChart"></canvas>
                </div>
            </div>
        </div>

        <div class="col-lg-4 d-flex flex-column gap-4">
            <div class="card glass-card p-4">
                <h5 class="fw-bold mb-4 text-dark">Quick Actions</h5>
                
                <a href="{{path('admin_manage_students')}}" class="action-btn action-btn-primary w-100 mb-3 text-decoration-none">
                    <div class="bg-white rounded-circle d-flex justify-content-center align-items-center me-3" style="width: 32px; height: 32px;">
                        <i class="fas fa-user-plus text-primary"></i>
                    </div>
                    Add New Student
                </a>

                <a href="{{path('admin_manage_teachers')}}" class="action-btn action-btn-success w-100 mb-3 text-decoration-none">
                    <div class="bg-white rounded-circle d-flex justify-content-center align-items-center me-3" style="width: 32px; height: 32px;">
                        <i class="fas fa-money-bill-wave text-success"></i>
                    </div>
                    Manage Teacher
                </a>

                <a href="{{path('admin_invoice_new')}}" class="action-btn action-btn-warning w-100 text-decoration-none">
                    <div class="bg-white rounded-circle d-flex justify-content-center align-items-center me-3" style="width: 32px; height: 32px;">
                        <i class="fas fa-receipt text-warning"></i>
                    </div>
                    Create Invoice
                </a>
            </div>

            <div class="card glass-card p-4 flex-grow-1">
                <h5 class="fw-bold mb-4 text-dark">Live Status</h5>
                
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <span class="text-muted fw-semibold">Active Students</span>
                    <span class="badge bg-light text-dark status-badge fs-6">{{ activeStudents ?? 0 }}</span>
                </div>
                
                <div class="d-flex justify-content-between align-items-center">
                    <span class="text-muted fw-semibold">Defaulters</span>
                    <span class="badge badge-soft-danger status-badge fs-6">{{ defaulters ?? 0 }}</span>
                </div>
            </div>
        </div>
    </div>

    <div class="card glass-card mt-4 p-4">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h5 class="fw-bold mb-0 text-dark">Recent Transactions</h5>
{#            <button class="btn btn-sm px-4 rounded-pill fw-bold" style="background: #e9e3ff; color: #4318FF;">View All</button>#}
        </div>

        <div class="table-responsive">
            <table class="table custom-table table-borderless align-middle mb-0">
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Description</th>
                        <th>Type</th>
                        <th>Amount</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                {% if transactions is defined and transactions|length > 0 %}
                    {% for tx in transactions %}
                        <tr>
                            <td class="text-muted fw-semibold">{{ tx.date ? tx.date|date('d M Y') : 'N/A' }}</td>
                            <td class="fw-bold text-dark">{{ tx.name }}</td>
                            <td class="text-muted text-capitalize">{{ tx.type }}</td>
                            <td class="fw-bold text-dark">₹ {{ tx.amount|number_format(2) }}</td>
                            <td>
                                {% if tx.status == 'paid' %}
                                    <span class="status-badge badge-soft-success">Paid</span>
                                {% elseif tx.status == 'expense' %}
                                    <span class="status-badge badge-soft-danger">Expense</span>
                                {% else %}
                                    <span class="status-badge badge-soft-pending">Pending</span>
                                {% endif %}
                            </td>
                        </tr>
                    {% endfor %}
                {% else %}
                    <tr>
                        <td colspan="5" class="text-center py-5 text-muted fw-semibold">
                            <i class="fas fa-folder-open fs-2 mb-3" style="color: #e2e8f0;"></i><br>
                            No transactions found
                        </td>
                    </tr>
                {% endif %}
                </tbody>
            </table>
        </div>
    </div>

</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
    document.addEventListener("DOMContentLoaded", function() {
        const ctx = document.getElementById('financeChart');

        if (ctx) {
            const context = ctx.getContext('2d');
            const incomeGrad = context.createLinearGradient(0, 0, 0, 300);
            incomeGrad.addColorStop(0, 'rgba(5, 205, 153, 0.2)');
            incomeGrad.addColorStop(1, 'rgba(5, 205, 153, 0)');

            new Chart(ctx, {
                type: 'line',
                data: {
                    labels: {{ months is defined ? months|json_encode|raw : '["Jan","Feb","Mar","Apr","May","Jun"]' }},
                    datasets: [
                        {
                            label: 'Income',
                            data: {{ incomeData is defined ? incomeData|json_encode|raw : '[12000, 19000, 15000, 25000, 22000, 30000]' }},
                            borderColor: '#05CD99',
                            backgroundColor: incomeGrad,
                            borderWidth: 3,
                            fill: true,
                            tension: 0.4,
                            pointBackgroundColor: '#ffffff',
                            pointBorderColor: '#05CD99',
                            pointBorderWidth: 2,
                            pointRadius: 4,
                            pointHoverRadius: 6
                        },
                        {
                            label: 'Expense',
                            data: {{ expenseData is defined ? expenseData|json_encode|raw : '[8000, 12000, 10000, 18000, 15000, 20000]' }},
                            borderColor: '#EE5D50',
                            borderWidth: 3,
                            borderDash: [5, 5],
                            fill: false,
                            tension: 0.4,
                            pointBackgroundColor: '#ffffff',
                            pointBorderColor: '#EE5D50',
                            pointBorderWidth: 2,
                            pointRadius: 4,
                            pointHoverRadius: 6
                        }
                    ]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            position: 'top',
                            align: 'end',
                            labels: { usePointStyle: true, boxWidth: 8, font: { family: 'Inter', weight: '600' } }
                        }
                    },
                    scales: {
                        y: {
                            beginAtZero: true,
                            grid: { borderDash: [4, 4], color: '#e2e8f0', drawBorder: false },
                            ticks: { font: { family: 'Inter', size: 11 }, color: '#a3aed1' }
                        },
                        x: {
                            grid: { display: false, drawBorder: false },
                            ticks: { font: { family: 'Inter', size: 11 }, color: '#a3aed1' }
                        }
                    }
                }
            });
        }
    });
</script>
{% endblock %}