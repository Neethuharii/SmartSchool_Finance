{% extends 'admin/dashboard/index.html.twig' %}

{% block title %}Manage Students - Admin Portal{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .glass-card { background: #ffffff; border: none; border-radius: 20px; box-shadow: 0 10px 30px rgba(112, 144, 176, 0.08); padding: 25px; }
        .custom-table th { color: #a3aed1; font-weight: 600; font-size: 0.85rem; text-transform: uppercase; border-bottom: 2px solid #f4f7fe; padding-bottom: 15px; }
        .custom-table td { padding: 15px 10px; border-bottom: 1px dashed #e2e8f0; color: #2b3674; vertical-align: middle; }
        
        .avatar-circle { width: 40px; height: 40px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: bold; color: white; font-size: 1.1rem; }
        .action-icon { color: #a3aed1; transition: 0.2s; margin: 0 5px; font-size: 1.1rem; border: none; background: none; cursor: pointer; }
        .action-icon:hover { color: #4318FF; transform: scale(1.1); }
        
        .status-badge { padding: 5px 12px; border-radius: 30px; font-size: 0.75rem; font-weight: 700; }
        .bg-active { background: #e0faf1; color: #05CD99; }
        .bg-inactive { background: #feecea; color: #EE5D50; }
        
       
        .bg-soft-primary { background: rgba(67, 24, 255, 0.1); color: #4318FF; }
        .bg-soft-danger { background: rgba(238, 93, 80, 0.1); color: #EE5D50; }
        .bg-soft-success { background: rgba(5, 205, 153, 0.1); color: #05CD99; }
    </style>
{% endblock %}

{% block body %}
<div class="container-fluid p-0">
    
    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="alert alert-{{ label == 'danger' ? 'danger' : 'success' }} alert-dismissible fade show shadow-sm" role="alert" style="border-radius: 12px;">
                {{ message }}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        {% endfor %}
    {% endfor %}

    <div class="d-flex justify-content-between align-items-center mb-4 gap-3">
        <div>
            <h2 class="fw-bold mb-1" style="color: #2b3674;">Manage Students</h2>
            <p class="text-muted mb-0">Total Registry: <span class="fw-bold text-dark">{{ students|length }}</span></p>
        </div>
        <button type="button" class="btn px-4 py-2 text-white fw-bold" style="background: #4318FF; border-radius: 12px;" data-bs-toggle="modal" data-bs-target="#addStudentModal">
            <i class="fas fa-plus me-2"></i> Add Student
        </button>
    </div>

    <div class="glass-card">
        <div class="table-responsive">
            <table class="table custom-table table-borderless align-middle mb-0">
                <thead>
                    <tr>
                        <th>Student Name</th>
                        <th>Admission No.</th>
                        <th>Class & Section</th>
                        <th>Financial Status</th>
                        
                        <th>Status</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                {% for student in students %}
                    <tr>
                        <td>
                            <div class="d-flex align-items-center gap-3">
                                <div class="avatar-circle shadow-sm" style="background: linear-gradient(135deg, #4318FF 0%, #868CFF 100%);">
                                    {{ student.firstName|first|upper }}
                                </div>
                                <div>
                                    <div class="fw-bold text-dark">{{ student.firstName }} {{ student.lastName }}</div>
                                    {# Mini Scholarship Tag #}
                                    {% for assign in student.studentDiscounts %}
                                        {% if assign.status == 'Active' %}
                                            <span class="badge bg-soft-primary text-primary border-0" style="font-size: 0.6rem;">
                                                <i class="fas fa-star me-1"></i> {{ assign.discount.name }}
                                            </span>
                                        {% endif %}
                                    {% endfor %}
                                </div>
                            </div>
                        </td>
                        <td class="fw-semibold text-muted">{{ student.admissionNo }}</td>
                        <td>
                            {% if student.section %}
                                <span class="badge bg-light text-primary border px-2 py-1">
                                    {{ student.section.academicClass.name }} - {{ student.section.name }}
                                </span>
                            {% else %}
                                <span class="text-muted small">Unassigned</span>
                            {% endif %}
                        </td>
                        <td>
                            {# Detailed Financial Status #}
                            {% set hasDiscount = false %}
                            {% for assign in student.studentDiscounts %}
                                {% if assign.status == 'Active' %}
                                    {% set hasDiscount = true %}
                                    <div class="small fw-bold text-primary">{{ assign.discount.name }}</div>
                                    <div class="text-muted" style="font-size: 0.7rem;">
                                        {{ assign.discount.type == 'percentage' ? assign.discount.value ~ '%' : '$' ~ assign.discount.value }} Waiver
                                    </div>
                                {% endif %}
                            {% endfor %}
                            {% if not hasDiscount %}
                                <span class="text-muted small">Standard Billing</span>
                            {% endif %}
                        </td>
                       {# <td>

                            {% set balance = student.remainingBalance(0.0) %}
                            {% if balance > 0 %}
                                <span class="badge bg-soft-danger text-danger fw-bold">
                                    Pending: ${{ balance|number_format(2) }}
                                </span>
                            {% elseif balance < 0 %}
                                <span class="badge bg-info text-white fw-bold">
                                    Credit: ${{ (balance * -1)|number_format(2) }}
                                </span>
                            {% else %}
                                <span class="badge bg-soft-success text-success fw-bold">
                                    <i class="fas fa-check-circle me-1"></i> Paid
                                </span>
                            {% endif %}
                        </td>#}
                        <td>
                            <span class="status-badge {{ student.status == 'active' ? 'bg-active' : 'bg-inactive' }}">
                                {{ student.status|capitalize }}
                            </span>
                        </td>
                        <td class="text-end">
                            <div class="d-flex justify-content-end gap-2">
                                <button class="action-icon" data-bs-toggle="modal" data-bs-target="#editModal{{ student.id }}">
                                    <i class="fas fa-pen text-primary"></i>
                                </button>
                                <form action="{{ path('admin_delete_student', {'id': student.id}) }}" method="POST" onsubmit="return confirm('Delete this record?');">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete_student_' ~ student.id) }}">
                                    <button type="submit" class="action-icon">
                                        <i class="fas fa-trash text-danger"></i>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>

                    {# EDIT MODAL (Per Student) #}
                    <div class="modal fade" id="editModal{{ student.id }}" tabindex="-1" aria-hidden="true">
                        <div class="modal-dialog modal-dialog-centered modal-lg">
                            <div class="modal-content rounded-4 border-0 shadow-lg">
                                <form action="{{ path('admin_edit_student', {'id': student.id}) }}" method="POST">
                                    <div class="modal-header border-0 p-4">
                                        <h5 class="fw-bold text-dark m-0">Edit Profile: {{ student.firstName }}</h5>
                                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                    </div>
                                    <div class="modal-body p-4 pt-0">
                                        <input type="hidden" name="_token" value="{{ csrf_token('edit_student_' ~ student.id) }}">
                                        <div class="row g-3">
                                            <div class="col-md-6">
                                                <label class="form-label small fw-bold">Admission Number</label>
                                                <input type="text" name="admission_no" class="form-control bg-light border-0 p-3" value="{{ student.admissionNo }}" required>
                                            </div>
                                            <div class="col-md-6">
                                                <label class="form-label small fw-bold">Status</label>
                                                <select name="status" class="form-select bg-light border-0 p-3">
                                                    <option value="active" {{ student.status == 'active' ? 'selected' : '' }}>Active</option>
                                                    <option value="inactive" {{ student.status == 'inactive' ? 'selected' : '' }}>Inactive</option>
                                                </select>
                                            </div>
                                            <div class="col-md-6">
                                                <label class="form-label small fw-bold">First Name</label>
                                                <input type="text" name="first_name" class="form-control bg-light border-0 p-3" value="{{ student.firstName }}" required>
                                            </div>
                                            <div class="col-md-6">
                                                <label class="form-label small fw-bold">Last Name</label>
                                                <input type="text" name="last_name" class="form-control bg-light border-0 p-3" value="{{ student.lastName }}" required>
                                            </div>
                                            <div class="col-md-12">
                                                <label class="form-label small fw-bold">Class & Section</label>
                                                <select name="class_and_section_id" class="form-select bg-light border-0 p-3" required>
                                                    {% for class in classes %}
                                                        <optgroup label="{{ class.name }}">
                                                            {% for section in class.sections %}
                                                                <option value="{{ section.id }}" {{ student.section and student.section.id == section.id ? 'selected' : '' }}>
                                                                    {{ class.name }} - {{ section.name }}
                                                                </option>
                                                            {% endfor %}
                                                        </optgroup>
                                                    {% endfor %}
                                                </select>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="modal-footer border-0 p-4">
                                        <button type="button" class="btn btn-light fw-bold" data-bs-dismiss="modal">Cancel</button>
                                        <button type="submit" class="btn text-white px-4 fw-bold" style="background: #4318FF;">Update Record</button>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>

{# ADD STUDENT MODAL #}
<div class="modal fade" id="addStudentModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content rounded-4 border-0">
            <form action="{{ path('admin_manage_students') }}" method="POST">
                <div class="modal-header border-0 p-4">
                    <h5 class="fw-bold m-0">Register New Student</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body p-4 pt-0">
                    <input type="hidden" name="_token" value="{{ csrf_token('add_student') }}">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label small fw-bold">Admission No.</label>
                            <input type="text" name="admission_no" class="form-control bg-light border-0 p-3" required>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small fw-bold">Status</label>
                            <select name="status" class="form-select bg-light border-0 p-3">
                                <option value="active">Active</option>
                                <option value="inactive">Inactive</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small fw-bold">First Name</label>
                            <input type="text" name="first_name" class="form-control bg-light border-0 p-3" required>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small fw-bold">Last Name</label>
                            <input type="text" name="last_name" class="form-control bg-light border-0 p-3" required>
                        </div>
                        <div class="col-md-12">
                            <label class="form-label small fw-bold">Class & Section</label>
                            <select name="class_and_section_id" class="form-select bg-light border-0 p-3" required>
                                <option value="">Choose Class...</option>
                                {% for class in classes %}
                                    <optgroup label="{{ class.name }}">
                                        {% for section in class.sections %}
                                            <option value="{{ section.id }}">{{ class.name }} - {{ section.name }}</option>
                                        {% endfor %}
                                    </optgroup>
                                {% endfor %}
                            </select>
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-0 p-4">
                    <button type="button" class="btn btn-light fw-bold" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn text-white px-4 fw-bold" style="background: #4318FF;">Save Student</button>
                </div>
            </form>
        </div>
    </div>
</div>
{% endblock %}