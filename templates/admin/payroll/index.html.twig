{% extends 'base.html.twig' %}

{% block title %}Admin - Generate Student Fees{% endblock %}

{% block body %}
<div class="container py-5">
    
    <div class="row justify-content-center">
        <div class="col-md-8">
            
         
            {% for message in app.flashes('success') %}
                <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
                    <i class="fas fa-check-circle me-2"></i> {{ message }}
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            {% endfor %}

            <div class="card shadow-sm border-0 rounded-3">
                <div class="card-body p-5 text-center">
                    
                    <div class="mb-4 text-success">
                        <i class="fas fa-file-invoice-dollar" style="font-size: 4rem;"></i>
                    </div>
                    
                    <h2 class="fw-bold mb-3">Generate Student Fee Invoices</h2>
                    <p class="text-muted mb-4">
                        Automatically generate and distribute tuition fee invoices for all enrolled students for the current academic term.
                    </p>
                    
                    {#<div class="bg-light rounded p-3 mb-4 d-inline-block border">
                        <span class="text-muted text-uppercase small fw-bold tracking-wide">Current Term</span>
                        <h4 class="fw-bold text-dark mb-0 mt-1">{{ currentTerm }}</h4>
                    </div>#}

                    <form action="{{ path('admin_fees_process') }}" method="POST">
                        <button type="submit" class="btn btn-success btn-lg rounded-pill px-5 shadow">
                            <i class="fas fa-paper-plane me-2"></i> Generate Invoices Now
                        </button>
                    </form>

                    <p class="small text-muted mt-4 fst-italic">
                        * Note: Students who already have an active invoice for will be skipped to prevent duplicate billing.
                    </p>
                </div>
            </div>

        </div>
    </div>
</div>
{% endblock %}